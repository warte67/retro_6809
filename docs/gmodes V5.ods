     </table:table-cell>
     <table:table-cell table:number-columns-repeated="14"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:style-name="ce31" office:value-type="string" calcext:value-type="string">
      <text:p>EXT_TILE_H:</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>(Word) Leftmost Tile Displayed Index (Tile Mode Only)</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="14"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:style-name="ce31" office:value-type="string" calcext:value-type="string">
      <text:p>EXT_TILE_V:</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>(Word) Topmost Tile Displayed Index (Tile Mode Only)</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="14"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:style-name="ce31" office:value-type="string" calcext:value-type="string">
      <text:p>EXT_PITCH:</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>(Word) Horizontal pitch of map/display in tiles/pixels</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="14"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:number-columns-repeated="16"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:style-name="ce31" office:value-type="string" calcext:value-type="string">
      <text:p>STD_PAGE:</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce32" office:value-type="string" calcext:value-type="string">
      <text:p>(Byte) active page within standard graphics memory</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="14"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell/>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>zero = inactive</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="14"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell/>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>non-zero = active display page</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="14"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:style-name="ce31" office:value-type="string" calcext:value-type="string">
      <text:p>STD_START:</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>(Word) Starting address of current STD mem page</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="14"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell table:style-name="ce31" office:value-type="string" calcext:value-type="string">
