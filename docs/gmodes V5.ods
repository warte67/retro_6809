     <table:table-cell table:style-name="ce5" office:value-type="string" calcext:value-type="string">
      <text:p>Sprite Notes:</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="15"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>Each sprite node is 8 bytes in size. This will require 2k of storage for 256 sprites.</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="15"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>The sprite table is stored within standard CPU addressable RAM and </text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="15"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p><text:s text:c="8"/>must be allocated by the running program.</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="15"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
