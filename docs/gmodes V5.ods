     </table:table-cell>
     <table:table-cell table:style-name="ce51" office:value-type="float" office:value="160" calcext:value-type="float">
      <text:p>160</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce51" table:formula="of:=[.B47]/[.$E$40]" office:value-type="float" office:value="100" calcext:value-type="float">
