    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell/>
     <table:table-cell table:style-name="ce35" office:value-type="string" calcext:value-type="string">
      <text:p>total:</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce46" table:formula="of:=SUM([.C51:.C54])" office:value-type="float" office:value="8" calcext:value-type="float">
