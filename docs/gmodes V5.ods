     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>0:FULLSCREEN, 1:WINDOWED</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="12"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell/>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>MONITOR</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce46" office:value-type="float" office:value="3" calcext:value-type="float">
      <text:p>3</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>0-7: Use Monitor Number</text:p>
     </table:table-cell>
     <table:table-cell table:number-columns-repeated="12"/>
    </table:table-row>
    <table:table-row table:style-name="ro2">
     <table:table-cell/>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>reserved</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce46" table:formula="of:=8-SUM([.C51:.C53])" office:value-type="float" office:value="3" calcext:value-type="float">
      <text:p>3</text:p>
     </table:table-cell>
     <table:table-cell office:value-type="string" calcext:value-type="string">
      <text:p>currently assigned bit flags</text:p>
     </table:table-cell>
