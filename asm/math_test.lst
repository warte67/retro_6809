0000                                  org     $0000
0000  3000                            fdb     start           ; SOFT_EXEC
                      
3000                                  org     $3000
3000                  start           
                                      ; crank the CPU speed some
3000  860E                            lda     #$0E    
3002  B71C02                          sta     SYS_STATE
                      
                      *               ; write float string into ACA
                      *               clr     MATH_ACA_POS
                      *               ldx     #test_aca_string
                      * st_1          lda     ,x+
                      *               sta     MATH_ACA_DATA
                      *               beq     st_2
                      *               bmi     st_2
                      *               bra     st_1
                      * st_2
                      *               ; write float string into ACB
                      *               clr     MATH_ACB_POS
                      *               ldx     #test_acb_string
                      * st_3          lda     ,x+
                      *               sta     MATH_ACB_DATA
                      *               beq     3f
                      *               bmi     3f
                      *               bra     st_3
                      
                                      ;
3005  CC0000                          ldd     #$0000
3008  FD1CA4                          std     MATH_ACA_INT
300B  CC0145                          ldd     #$0145
300E  FD1CA6                          std     MATH_ACA_INT+2  
                                      ;
3011  CC0000                          ldd     #$0000
3014  FD1CAE                          std     MATH_ACB_INT
3017  CC0010                          ldd     #$0010
301A  FD1CB0                          std     MATH_ACB_INT+2
                                      ;
                      
                                      
                      
                      
                                      ; display ACA
301D  7F1C9E          3               clr     MATH_ACA_POS
3020  B61C9F          1               lda     MATH_ACA_DATA
3023  2705                            beq     2f
3025  BDF433                          jsr     char_out
3028  20F6                            bra     1b
302A                  2
302A  860A                            lda     #$0a
302C  BDF433                          jsr     char_out
                      
                                      ; display ACB
302F  7F1CA8                          clr     MATH_ACB_POS
3032  B61CA9          1               lda     MATH_ACB_DATA
3035  2705                            beq     2f
3037  BDF433                          jsr     char_out
303A  20F6                            bra     1b
303C                  2
303C  860A                            lda     #$0a
303E  BDF433                          jsr     char_out
                      
3041                  st_4
                                      ; perform a math operation
                                      * clr   MATH_ACA_INT+0
                                      * clr   MATH_ACA_INT+1
                                      * clr   MATH_ACA_INT+2
                                      * clr   MATH_ACA_INT+3
                                      * inc   MATH_ACA_INT+3
                                      * lda   #MOP_RND_SEED
                                      * sta   MATH_OPERATION
                      
3041  8600                            lda     #MOP_RANDOM
3043  B71CBC                          sta     MATH_OPERATION
                      
                                      ; display ACR (result)
3046  7F1CB2                          clr     MATH_ACR_POS
3049  B61CB3          1               lda     MATH_ACR_DATA
304C  2705                            beq     2f
304E  BDF433                          jsr     char_out
3051  20F6                            bra     1b
3053                  2
3053  860A                            lda     #$0a
3055  BDF433                          jsr     char_out
                      
                      
                      
                      
                                      ; output true / false result
                      *               ldx     #str_true
                      *               tst     MATH_ACR_INT+3
                      *               beq     st_5
                      *               bra     st_6
                      * st_5
                      *               ldx     #str_false
                      * st_6
                      *               jsr     line_out
                      
3058                  done    ; clean up and return
3058  860A                            lda     #$0a
305A  BDF433                          jsr     char_out
305D  39                              rts
                      
                      
                      
                      
305E  352E3300        test_aca_string fcn     "5.3"
3062  332E31343135323900 test_acb_string fcn     "3.141529"
306B  5452554500      str_true        fcn     "TRUE"
3070  46414C534500    str_false       fcn     "FALSE"
3076  40              test_raw        fcb     $40
3077  49                              fcb     $49
3078  0E                              fcb     $0e
3079  D0                              fcb     $d0
