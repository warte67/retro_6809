                                      ; is the string 2 character a terminator?
F2D3  E6A4                            ldb     ,y              ; fetch a character from the second string
F2D5  2728                            beq     str2_cmp_term   ; is a null-terminator? verify other string
F2D7  C120                            cmpb    #' '            ; is it a space character?
F2D9  2724                            beq     str2_cmp_term   ; branch to verify other strings termination
F2DB  C122                            cmpb    #'"'            ; is it a double-quote character?
F2DD  2720                            beq     str2_cmp_term   ; branch to verify other strings termination
F2DF  C10D                            cmpb    #$0d            ; is it an ENTER character?
F2E1  271C                            beq     str2_cmp_term   ; branch to verify other strings termination
