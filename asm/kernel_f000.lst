F2E8                  dct_output      ; output the status string
F2E8  BDF41C                          jsr     line_out        ; output the syntax error
F2EB                  dct_done        ; clean up and return
F2EB  3502                            puls    A               ; clean up the stack, Token ID in A
F2ED  3534                            puls    B,X,Y           ; restore the working registers
F2EF  39                              rts                     ; return from subroutine
                      
