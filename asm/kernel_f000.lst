                      ; ***********************************************************************
                      ; *     kernel_f000.asm                                                 *
                      ; *                                                                     *
                      ; *     a.k.a. The Basic Input and Output System (BIOS)                 *
                      ; ***********************************************************************
                      ; *                                                                     *
                      ; *     LINUX:          ./asm/build.sh asm/kernel_f000                  *
                      ; *             or                                                      *       
                      ; *     WINDOWS:        asm kernel_f000                                 *
                      ; *                                                                     *
                      ; *     build.sh:                                                       *
                      ; *             #!/bin/bash                                             *
                      ; *             #lwasm -9 test.asm --format=ihex -otest.hex -ltest.lst  *
                      ; *             echo "lwasm -9 $1.asm --format=ihex -o$1.hex -l$1.lst"  *
                      ; *             lwasm -9 $1.asm --format=ihex -o$1.hex -l$1.lst         *
                      ; *                                                                     *
                      ; *     asm.bat:                                                        *
                      ; *             @set arg1=%1                                            *
                      ; *             asm6809 -H -9 %arg1%.asm -o %arg1%.hex -l %arg1%.lst    *
                      ; ***********************************************************************
0000                                  INCLUDE "memory_map.asm"
                      ;  **********************************************
                      ;  * Allocated 64k Memory Mapped System Symbols *
                      ;  **********************************************
0000                  SOFT_VECTORS    equ   $0000
                      
                                ; Software Interrupt Vectors:
0000                  SOFT_RSRVD      equ   $0000    ; Motorola RESERVED Software Interrupt Vector
0002                  SOFT_SWI3       equ   $0002    ; SWI3 Software Interrupt Vector
0004                  SOFT_SWI2       equ   $0004    ; SWI2 Software Interrupt Vector
0006                  SOFT_FIRQ       equ   $0006    ; FIRQ Software Interrupt Vector
0008                  SOFT_IRQ        equ   $0008    ; IRQ Software Interrupt Vector
000A                  SOFT_SWI        equ   $000A    ; SWI / SYS Software Interrupt Vector
000C                  SOFT_NMI        equ   $000C    ; NMI Software Interrupt Vector
000E                  SOFT_RESET      equ   $000E    ; RESET Software Interrupt Vector
                      
0010                  ZERO_PAGE       equ   $0010
0100                  SYSTEM_STACK    equ   $0100
0300                  SSTACK_TOP      equ   $0300    ; Top of the system stack space
0300                  USER_STACK      equ   $0300
0400                  USTACK_TOP      equ   $0400    ; Top of the user stack space
                      
                                ; Display Buffer
0400                  SCREEN_BUFFER    equ   $0400
                      
                                ; Device Registers:
1C00                  HDW_REGS        equ   $1C00    ; Begin Device Hardware Registers
                      
1C00                  STD_VID_MAX     equ   $1C00    ;  (Word) Standard Video Buffer Max
                      
1C02                  SYS_STATE       equ   $1C02    ;  (Byte) System State Register
                                ; SYS_STATE: ABCD.SSSS
                                ;      A:0   = Error: Standard Buffer Overflow
                                ;      B:0   = Error: Extended Buffer Overflow
                                ;      C:0   = Error: Reserved
                                ;      D:0   = Error: Reserved
                                ;      S:$0  = CPU Clock  25 khz.
                                ;      S:$1  = CPU Clock  50 khz.
                                ;      S:$2  = CPU Clock 100 khz.
                                ;      S:$3  = CPU Clock 200 khz.
                                ;      S:$4  = CPU Clock 333 khz.
                                ;      S:$5  = CPU Clock 416 khz.
                                ;      S:$6  = CPU Clock 500 khz.
                                ;      S:$7  = CPU Clock 625 khz.
                                ;      S:$8  = CPU Clock 769 khz.
                                ;      S:$9  = CPU Clock 833 khz.
                                ;      S:$A  = CPU Clock 1.0 mhz.
                                ;      S:$B  = CPU Clock 1.4 mhz.
                                ;      S:$C  = CPU Clock 2.0 mhz.
                                ;      S:$D  = CPU Clock 3.3 mhz.
                                ;      S:$E  = CPU Clock 5.0 mhz.
                                ;      S:$F  = CPU Clock ~10.0 mhz. (unmetered)
                      
1C03                  SYS_SPEED       equ   $1C03    ;  (Word) Approx. Average CPU Clock Speed
                      
1C05                  DSP_GRES        equ   $1C05    ;  (Byte) Screen Resolution Register
                                ; DSP_GRES: BBRR.HHVV
                                ;     BB:00 = Standard Graphics 1-bpp (2-color mode)
                                ;     BB:01 = Standard Graphics 2-bpp (4-color mode)
                                ;     BB:10 = Standard Graphics 4-bpp (16-color mode)
                                ;     BB:11 = Standard Graphics 8-bpp (256-color mode)
                                ;     RR:00 = 16:9  aspect (1.777778)
                                ;     RR:01 = 16:10 aspect (1.600000)
                                ;     RR:10 = 16:11 aspect (1.454545)
                                ;     RR:11 = 16:12 aspect (1.333333)
                                ;     HH:00 = 4x Horizontal Overscan Multiplier
                                ;     HH:01 = 3x Horizontal Overscan Multiplier
                                ;     HH:10 = 2x Horizontal Overscan Multiplier
                                ;     HH:11 = 1x Horizontal Overscan Multiplier
                                ;     VV:00 = 4x Vertical Overscan Multiplier
                                ;     VV:01 = 3x Vertical Overscan Multiplier
                                ;     VV:10 = 2x Vertical Overscan Multiplier
                                ;     VV:11 = 1x Vertical Overscan Multiplier
                      
1C06                  DSP_EXT         equ   $1C06    ;  (Byte) Extended Graphics Register
                                ; DSP_EXT: ABCD.EFGG
                                ;      AA:00 = Extended Graphics 1bpp (2-color mode)
                                ;      AA:01 = Extended Graphics 2bpp (4-color mode)
                                ;      AA:10 = Extended Graphics 4bpp (16-color mode)
                                ;      AA:11 = Extended Graphics 4bpp (16-color mode)
                                ;      B:0   = Extended Graphics: DISABLED
                                ;      B:1   = Extended Graphics: ENABLED
                                ;      C:0   = Extended Extended Mode: BITMAP
                                ;      C:1   = Extended Extended Mode: TILES
                                ;      D:0   = Standard Graphics: DISABLED
                                ;      D:1   = Standard Graphics: ENABLED
                                ;      E:0   = Standard Display Mode: TEXT
                                ;      E:1   = Standard Display Mode: BITMAP
                                ;      F:0   = VSYNC OFF
                                ;      F:1   = VSYNC ON
                                ;      B:0   = Fullscreen Enabled( emulator only )
                                ;      B:1   = Windowed Enabled ( emulator only )
                      
1C07                  DSP_TXT_COLS    equ   $1C07    ;  (Byte) READ-ONLY Text Screen Columns
1C08                  DSP_TXT_ROWS    equ   $1C08    ;  (Byte) READ-ONLY Text Screens Rows
                      
1C09                  DSP_PAL_IDX     equ   $1C09    ;  (Byte) Color Palette Index
                                ; DSP_PAL_IDX: 0-255
                                ; Note: Use this register to set the index into theColor Palette.
                                ;   Set this value prior referencing color data (DSP_PAL_CLR).
                      
1C0A                  DSP_PAL_CLR     equ   $1C0A    ;  (Word) Indexed Color Palette Data
                                ; DSP_PAL_CLR: Color Data A4R4G4B4 format
                                ; Note: This is the color data for an individual palette entry.
                                ;     Write to DSP_PAL_IDX with the index within the color palette
                                ;     prior to reading or writing the color data in the DSP_PAL_CLR register.
                      
1C0C                  DSP_GLYPH_IDX    equ   $1C0C    ;  (Byte) Text Glyph Index
                                ; DSP_GLYPH_IDX: 0-256
                                ; Note: Set this register to index a specific text glyph. Set this value
                                ;     prior to updating glyph pixel data.
                      
1C0D                  DSP_GLYPH_DATA    equ   $1C0D    ;  (8-Bytes) Text Glyph Pixel Data Array
                                ; DSP_GLYPH_DATA: 8 rows of binary encoded glyph pixel data
                                ; Note: Each 8x8 text glyph is composed of 8 bytes. The first byte in this
                                ;     array represents the top line of 8 pixels. Each array entry represents
                                ;     a row of 8 pixels.
                      
                                ; Debug Hardware Registers:
1C15                  DBG_BEGIN       equ   $1C15    ;  start of mouse cursor hardware registers
1C15                  DBG_TEMP        equ   $1C15    ;  (Byte) Simple Debug test register
1C16                  DBG_END         equ   $1C16    ; End Debug Registers
                      
                                ; Mouse Cursor Hardware Registers:
1C16                  CSR_BEGIN       equ   $1C16    ;  start of mouse cursor hardware registers
1C16                  CSR_XPOS        equ   $1C16    ;  (Word) horizontal mouse cursor coordinate
1C18                  CSR_YPOS        equ   $1C18    ;  (Word) vertical mouse cursor coordinate
1C1A                  CSR_XOFS        equ   $1C1A    ;  (Byte) horizontal mouse cursor offset
1C1B                  CSR_YOFS        equ   $1C1B    ;  (Byte) vertical mouse cursor offset
1C1C                  CSR_SCROLL      equ   $1C1C    ;  (Signed) MouseWheel Scroll: -1, 0, 1
1C1D                  CSR_FLAGS       equ   $1C1D    ;  (Byte) mouse button flags:
                                ;  CSR_FLAGS:
                                ;       bits 0-5: button states
                                ;       bits 6-7: number of clicks
1C1E                  CSR_BMP_INDX    equ   $1C1E    ;  (Byte) mouse cursor bitmap pixel offset
1C1F                  CSR_BMP_DATA    equ   $1C1F    ;  (Byte) mouse cursor bitmap pixel index color
1C21                  CSR_PAL_INDX    equ   $1C21    ;  (Byte) mouse cursor color palette index (0-15)
1C22                  CSR_PAL_DATA    equ   $1C22    ;  (Word) mouse cursor color palette data RGBA4444
1C24                  CSR_END         equ   $1C24    ; End Mouse Registers
1C24                  GFX_END         equ   $1C24    ; End of GFX Device Registers
                      
1C24                  KEY_BEGIN       equ   $1C24    ; Start of the Keyboard Register space
1C24                  CHAR_Q_LEN      equ   $1C24    ;   (Byte) # of characters waiting in queue        (Read Only)
1C25                  CHAR_SCAN       equ   $1C25    ;   (Byte) read next character in queue (not popped when read)
1C26                  CHAR_POP        equ   $1C26    ;   (Byte) read next character in queue (not popped when read)
1C27                  XKEY_BUFFER     equ   $1C27    ;   (128 bits) 16 bytes for XK_KEY data buffer     (Read Only)
1C37                  EDT_BFR_CSR     equ   $1C37    ;   (Byte) cursor position within edit buffer     (Read/Write)
1C38                  EDT_BUFFER      equ   $1C38    ;   line editing character buffer                 (Read/Write)
1C78                  KEY_END         equ   $1C78    ; End of the Keyboard Register space
                      
                          ; 5000 ($1388) bytes remaining for additional registers.
1C78                  RESERVED        equ   $1C78
                      
                                ; User RAM (32K)
3000                  USER_RAM        equ   $3000
                      
                                ; Paged RAM (8K)
B000                  PAGED_RAM       equ   $B000
                      
                                ; PAGED ROM (8K bytes)
D000                  PAGED_ROM       equ   $D000
                      
                                ; KERNEL ROM (4K bytes)
F000                  KERNEL_ROM      equ   $F000
                      
                                ; Hardware Interrupt Vectors:
FFF0                  HARD_RSRVD      equ   $FFF0    ; Motorola RESERVED Hardware Interrupt Vector
FFF2                  HARD_SWI3       equ   $FFF2    ; SWI3 Hardware Interrupt Vector
FFF4                  HARD_SWI2       equ   $FFF4    ; SWI2 Hardware Interrupt Vector
FFF6                  HARD_FIRQ       equ   $FFF6    ; FIRQ Hardware Interrupt Vector
FFF8                  HARD_IRQ        equ   $FFF8    ; IRQ Hardware Interrupt Vector
FFFA                  HARD_SWI        equ   $FFFA    ; SWI / SYS Hardware Interrupt Vector
FFFC                  HARD_NMI        equ   $FFFC    ; NMI Hardware Interrupt Vector
FFFE                  HARD_RESET      equ   $FFFE    ; RESET Hardware Interrupt Vector
                      ; END of definitions
                      
                      ; Software Vectors
0000                          org     $0000   
0000  F022            VECT_RSRVD      fdb     RSRVD_start     ; This will likely be used as the EXEC vector
0002  F024            VECT_SWI3       fdb     SWI3_start      ; SWI3 Software Interrupt Vector
0004  F026            VECT_SWI2       fdb     SWI2_start      ; SWI2 Software Interrupt Vector
0006  F028            VECT_FIRQ       fdb     FIRQ_start      ; FIRQ Software Interrupt Vector
0008  F02A            VECT_IRQ        fdb     IRQ_start       ; IRQ Software Interrupt Vector
000A  F02C            VECT_SWI        fdb     SWI_start       ; SWI / SYS Software Interrupt Vector
000C  F02E            VECT_NMI        fdb     NMI_start       ; NMI Software Interrupt Vector 
000E  F032            VECT_RESET      fdb     kernel_start    ; RESET Software Interrupt Vecto        r       
                              
                      
                      ; system zero-page variables
0010  E4              cursor_attrib   fcb     $e4;
0011  0000            cursor_addr     fdb     $0000;
0013  00              var1            fcb     0;
0014  00              var2            fcb     0;
                      
                      
                      
                      
                      ; Kernel Jump Vector Calls      
F000                          org     KERNEL_ROM              
F000  6E9F0000        KRNL_RSRVD      jmp     [VECT_RSRVD]    ; This will likely be used as t he EXEC vector
F004  6E9F0002        KRNL_SWI3       jmp     [VECT_SWI3 ]    ; SWI3 Software Interrupt Vector        
F008  6E9F0004        KRNL_SWI2       jmp     [VECT_SWI2 ]    ; SWI2 Software Interrupt Vector
F00C  6E9F0006        KRNL_FIRQ       jmp     [VECT_FIRQ ]    ; FIRQ Software Interrupt Vector
F010  6E9F0008        KRNL_IRQ        jmp     [VECT_IRQ  ]    ; IRQ Software Interrupt Vector
F014  6E9F000A        KRNL_SWI        jmp     [VECT_SWI  ]    ; SWI / SYS Software Interrupt Vector
F018  6E9F000C        KRNL_NMI        jmp     [VECT_NMI  ]    ; NMI Software Interrupt Vector
F01C  6E9F000E        KRNL_RESET      jmp     [VECT_RESET]    ; RESET Software Interrupt Vector       
                      
                      ; a null vectors (i.e. an infinate loop traps for vector testing)
F020  20FE            KRNL_UNDEF      bra     KRNL_UNDEF
                      
F022  20FE            RSRVD_start     bra     RSRVD_start     ; EXEC program
F024  20FE            SWI3_start      bra     SWI3_start      ; SWI3 Implementation
F026  20FE            SWI2_start      bra     SWI2_start      ; SWI2 Implementation
F028  20FE            FIRQ_start      bra     FIRQ_start      ; FIRQ Implementation
F02A  20FE            IRQ_start       bra     IRQ_start       ; IRQ Implementation
F02C  20FE            SWI_start       bra     SWI_start       ; SWI / SYS Implementation
F02E  20FE            NMI_start       bra     NMI_start       ; NMI Implementation
F030  20FE            RESET_start     bra     RESET_start     ; RESET Implementation
                      
                      
F032                  kernel_start
                              ; initialize both stack pointers
F032  10CE0300                        lds     #SSTACK_TOP
F036  CE0400                          ldu     #USTACK_TOP
                      
                      ; SYS_STATE: ABCD.SSSS
                      ;      A:0   = Error: Standard Buffer Overflow
                      ;      B:0   = Error: Extended Buffer Overflow
                      ;      C:0   = Error: Reserved
                      ;      D:0   = Error: Reserved
                      ;      S:$0  = CPU Clock  25 khz.
                      ;      S:$1  = CPU Clock  50 khz.
                      ;      S:$2  = CPU Clock 100 khz.
                      ;      S:$3  = CPU Clock 200 khz.
                      ;      S:$4  = CPU Clock 333 khz.
                      ;      S:$5  = CPU Clock 416 khz.
                      ;      S:$6  = CPU Clock 500 khz.
                      ;      S:$7  = CPU Clock 625 khz.
                      ;      S:$8  = CPU Clock 769 khz.
                      ;      S:$9  = CPU Clock 833 khz.
                      ;      S:$A  = CPU Clock 1.0 mhz.
                      ;      S:$B  = CPU Clock 1.4 mhz.
                      ;      S:$C  = CPU Clock 2.0 mhz.
                      ;      S:$D  = CPU Clock 3.3 mhz.
                      ;      S:$E  = CPU Clock 5.0 mhz.
                      ;      S:$F  = CPU Clock ~10.0 mhz. (unmetered)
                      
F039  860A                            lda     #$0A
F03B  B71C02                          sta     SYS_STATE
                      
                      ;       DSP_GRES: BBRR.HHVV
                      ;           BB:00 = Standard Graphics 1-bpp (2-color mode)      
                      ;           BB:01 = Standard Graphics 2-bpp (4-color mode)      
                      ;           BB:10 = Standard Graphics 4-bpp (16-color mode)     
                      ;           BB:11 = Standard Graphics 8-bpp (256-color mode)    
                      ;           RR:00 = 16 / 9      Aspect:
                      ;           RR:01 = 16 / 10     Aspect:
                      ;           RR:10 = 16 / 11     Aspect:
                      ;           RR:11 = 16 / 12     Aspect:
                      ;           HH:00 = 4x Horizontal Overscan Multiplier
                      ;           HH:01 = 3x Horizontal Overscan Multiplier
                      ;           HH:10 = 2x Horizontal Overscan Multiplier
                      ;           HH:11 = 1x Horizontal Overscan Multiplier
                      ;           VV:00 = 4x Vertical Overscan Multiplier
                      ;           VV:01 = 3x Vertical Overscan Multiplier
                      ;           VV:10 = 2x Vertical Overscan Multiplier
                      ;           VV:11 = 1x Vertical Overscan Multiplier
                      
F03E  86CA                            lda     #$CA
F040  B71C05                          sta     DSP_GRES
                      
                      ; DSP_EXT: ABCD.EFGG
                      ;      AA:00 = Extended Graphics 1bpp (2-color mode)
                      ;      AA:01 = Extended Graphics 2bpp (4-color mode)
                      ;      AA:10 = Extended Graphics 4bpp (16-color mode)
                      ;      AA:11 = Extended Graphics 4bpp (16-color mode)
                      ;      B:0   = Extended Graphics: DISABLED
                      ;      B:1   = Extended Graphics: ENABLED
                      ;      C:0   = Extended Extended Mode: BITMAP
                      ;      C:1   = Extended Extended Mode: TILES
                      ;      D:0   = Standard Graphics: DISABLED
                      ;      D:1   = Standard Graphics: ENABLED
                      ;      E:0   = Standard Display Mode: TEXT
                      ;      E:1   = Standard Display Mode: BITMAP
                      ;      F:0   = VSYNC OFF
                      ;      F:1   = VSYNC ON
                      ;      B:0   = Fullscreen Enabled( emulator only )
                      ;      B:1   = Windowed Enabled ( emulator only )
                      
F043  86C9                            lda     #$C9
F045  B71C06                          sta     DSP_EXT
                      
                      
                              ; clear out the text buffer
F048                  cls             
F048  8E0400                          ldx     #SCREEN_BUFFER
F04B  CC20B4                          ldd     #$20B4
F04E  ED81            1               std     ,x++
F050  8C1C00                          cmpx    #STD_VID_MAX
F053  2DF9                            blt     1b
                      
F055  8D02            2               bsr     line_edit
                                      
F057  20EF                            bra     cls
                      
                      
                      ; output the line edit buffer
F059                  line_edit
F059  7F1C38                          clr     EDT_BUFFER
                      
F05C                  6       ; check for ENTER press
F05C  B61C25                          lda     CHAR_SCAN       ; scan for a character waiting in the queue
F05F  810D                            cmpa    #$0d            ; is it the ENTER key?
F061  260B                            bne     0f              ; nope, continue to render the text line editor
F063  B61C26                          lda     CHAR_POP        ; pop the ENTER from the queue before returning
F066  CC20B4                          ldd     #$20b4          ; load a colored space
F069  ED9F0011                        std     [cursor_addr]   ; overrite the last colored cursor
F06D  39                              rts                     ; return from the line editor subroutine
F06E                  0       ; begine the line edit routine
F06E  CE0400                          ldu     #SCREEN_BUFFER  ; reserve the start of the standard buffer
F071  108E1C38                        ldy     #EDT_BUFFER     ; start of the character line edit buffer
F075  8E0400                          ldx     #SCREEN_BUFFER  ; point to the start of the display buffer
F078  B61C37                          lda     EDT_BFR_CSR     ; fetch the cursor position
F07B  3402                            pshs    a               ; save it on the stack as a local variable      
F07D  2604                            bne     1f              ; cursor position is not zero, begin text
F07F  A6A4                            lda     ,y              ; load the first character in the buffer
F081  261D                            bne     4f              ; if its not zero, display the cursor
F083                  1       ; start of the line
F083  B61C37                          lda     EDT_BFR_CSR     ; load the cursor position
F086  270E                            beq     3f              ; if theres no character, display the cursor
F088                  2       ; display up to the cursor position
F088  A6A0                            lda     ,y+             ; fetch a character from the edit buffer
F08A  270A                            beq     3f              ; null character (end of line)
F08C  C6B4                            ldb     #$B4            ; color attribute
F08E  ED81                            std     ,x++            ; display the character with its color  
F090  6AE4                            dec     0,s             ; decrease the local cursor position
F092  270C                            beq     4f              ; brach if the cursor is over a character
F094  20F2                            bra     2b              ; continue displaying characters
F096                  3       ; cursor at end of the line
F096  3502                            puls    a               ; repair the stack
F098  8620                            lda     #$20            ; load a space
F09A  A781                            sta     ,x++            ; display the space
F09C  8D14                            bsr     flash_the_cursor        
F09E  20BC                            bra     6b              ; loop and display changes in the edit buffer
F0A0                  4       ; cursor over a character
F0A0  3502                            puls    a               ; clean up the stack
F0A2  A6A0                            lda     ,y+             ; load the next character from the buffer
F0A4  A781                            sta     ,x++            ; ignore the attribute
                              ; flash the cursor
F0A6  8D0A                            bsr     flash_the_cursor
F0A8                  5       ; finish the line
F0A8  A6A0                            lda     ,y+             ; load the next character from the buffer
F0AA  27B0                            beq     6b              ; loop back to the top if done
F0AC  C6B4                            ldb     #$b4            ; load the basic screen attribute
F0AE  ED81                            std     ,x++            ; display the next character with its color
F0B0  20F6                            bra     5b              ; continue until the line is finished
                      
F0B2                  flash_the_cursor
F0B2  3446                            pshs    a,b,u           ; save these on the stack
F0B4  B60010                          lda     cursor_attrib   ; load the next cursor color
F0B7  4C                              inca                    ; increment it
F0B8  840F                            anda    #$0f            ; mask off the foreground color
F0BA  8AF0                            ora     #$f0            ; foreground 15 = opaque black
F0BC  B70010                          sta     cursor_attrib   ; store the new attribute
F0BF  F61C37                          ldb     EDT_BFR_CSR     ; load the cursor position
F0C2  58                              lslb                    ; skip the attribue
F0C3  5C                              incb                    ; increment the attribute color
F0C4  A7C5                            sta     b, u            ; update the characters color
F0C6  5A                              decb                    ; now index the character
F0C7  33C5                            leau    b,u             ; load that characters address
F0C9  FF0011                          stu     cursor_addr     ; store it on the zero-page
F0CC  3546                            puls    a,b,u           ; pop these off the stack
F0CE  39                              rts                     ; return when done
                      
                      
                      
                      
                      
                      
                      
                      
                      ; ROM Based Hardware Vectors
FFF0                                  org     $FFF0
FFF0  F000                            fdb     KRNL_RSRVD      ; HARD_RSRVD       RESERVED Hardware Interrupt Vector
FFF2  F004                            fdb     KRNL_SWI3       ; HARD_SWI3        SWI3 Hardware Interrupt Vector
FFF4  F008                            fdb     KRNL_SWI2       ; HARD_SWI2        SWI2 Hardware Interrupt Vector
FFF6  F00C                            fdb     KRNL_FIRQ       ; HARD_FIRQ        FIRQ Hardware Interrupt Vector
FFF8  F010                            fdb     KRNL_IRQ        ; HARD_IRQ         IRQ Hardware Interrupt Vector
FFFA  F014                            fdb     KRNL_SWI        ; HARD_SWI         SWI / SYS Hardware Interrupt Vector
FFFC  F018                            fdb     KRNL_NMI        ; HARD_NMI         NMI Hardware Interrupt Vector
FFFE  F01C                            fdb     KRNL_RESET      ; HARD_RESET       RESET Hardware Interrupt Vector
                      
                      
                      ; *****************************************************************
                      ;
                      ;   Text Mode Control Characters ($00 - $1f):
                      ; $00  00000000  Null character
                      ; $01  00000001  Set Default Character #                
                      ; $02  00000010  Set Attribute #                        
                      ; $03  00000011  Set FG Color #                         
                      ; $04  00000100  Set BG Color #                         
                      ; $05  00000101  Position Cursor To Column #            
                      ; $06  00000110  Position Cursor To Row #               
                      ; $07  00000111  Bell, Alert
                      ; $08  00001000  Backspace
                      ; $09  00001001  Horizontal Tab; $0A  00001010  [No Operation]                          
                      ; $0B  00001011                                         
                      ; $0C  00001100  Clear Screen To Default Character      
                      ; $0D  00001101  Carriage Return (ENTER); $0E  00001110                                         
                      ; $0F  00001111                                         
                      ; $10  00010000  Scroll Up                              
                      ; $11  00010001  Scroll Down                            
                      ; $12  00010010  Scroll Left                            
                      ; $13  00010011  Scroll Right                           
                      ; $14  00010100  Cursor Up                              
                      ; $15  00010101  Cursor Down                            
                      ; $16  00010110  Cursor Left                            
                      ; $17  00010111  Cursor Right                           
                      ; $18  00011000  Home Cursor                            
                      ; $19  00011001  Hide Cursor                            
                      ; $1A  00011010  Show Cursor                            
                      ; $1B  00011011  [Escape]; $1C  00011100                                        
                      ; $1D  00011101                                         
                      ; $1E  00011110                                         
                      ; $1F  00011111  Uncontrolled Character ($00-1f)        
                      ;
                      ; *****************************************************************
