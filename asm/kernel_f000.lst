F430                  char_out        ; output a formatted text character based on A
                                      ; jsr   [CHROUT_VECT]
F430                  char_out_main   ; the main CHROUT routine
F430  3416                            pshs    d,x
                      
F432  8120                            cmpa    #$20            ; is a printable character $20 - $ff
F434  2C09                            bge     1f              ; yup, go print it
F436  810A                            cmpa    #$0a            ; line feed ?
F438  2603                            bne     2f              ; no, skip to next
F43A  BDF488                          jsr     csr_new_line    ; perform a new line
F43D                  2       ; skip to end
F43D  2029                            bra     0f              ; just skip everything
F43F                  1       ; output a printable character $20 - $ff
F43F  BDF4DD                          jsr     cursor_address  ; X = CSR_ADDR          
F442  F60015                          ldb     TXT_ATTR        ; fetch the default color attribute
F445  ED84                            std     ,x              ; store it on screen
F447  7C0013                          inc     CSR_COL         ; increase the cursors column
                                      ; handle line wrap and scrolling
F44A  B60013                          lda     CSR_COL         ; load cursor column
F44D  B11C0A                          cmpa    DSP_TXT_COLS    ; compare with max displayed columns
F450  2C02                            bge     1f              ; if greater or equal
F452  2014                            bra     0f              ; skip and return
F454                  1       ; if (CSR_COL >= DSP_TXT_COLS)
F454  7F0013                          clr     CSR_COL         ; clear CSR_COL
F457  7C0014                          inc     CSR_ROW         ; increment CSR_ROW
F45A  B60014                          lda     CSR_ROW         ; load CSR_ROWS
F45D  B11C0B                          cmpa    DSP_TXT_ROWS    ; if (CSR_ROW < DSP_TXT_ROWS)
F460  2D06                            blt     0f              ;       clean up and return
F462  BDF4A7                          jsr     std_text_scroll ; scroll the text screen
F465  7A0014                          dec     CSR_ROW         ; CSR_ROW--
F468                  0       ; clean up and return
F468  3516                            puls    d,x             ; restore the working registers
F46A  39                              rts                     ; return
                      
                              
F46B                  cls     ; clear out the text buffer     
F46B  3416                            pshs    d, x            ; store the working registers
F46D  7F0013                          clr     CSR_COL         ; cursor column = 0
F470  7F0014                          clr     CSR_ROW         ; cursor row = 0
F473  BDF4DD                          jsr     cursor_address  ; X = cursor address based on CSR_COL and CSR_ROW
F476  8E0400                          ldx     #STD_VID_MIN    ; point to the start of the text buffer
F479  8620                            lda     #$20            ; set next character to space
F47B  F60015                          ldb     TXT_ATTR        ; load the characters color
F47E                  1       ; cls main loop 
F47E  ED81                            std     ,x++            ; store the space with its color attribute
F480  8C1C00                          cmpx    #STD_VID_MAX    ; are we at the end of the text buffer?
F483  2DF9                            blt     1b              ;       loop if not
F485  3516                            puls    d, x            ; restore the working registers
F487  39                              rts                     ; return
                      
                      
F488                  csr_new_line    ; perform a line-feed and a carriage return with scrolling
F488  3412                            pshs    a, x            ; store the working registers
F48A  7F0013                          clr     CSR_COL         ; set cursor column to zero
F48D  7C0014                          inc     CSR_ROW         ; increment the cursor row
F490  B60014                          lda     CSR_ROW         ; A = cursor row
F493  B11C0B                          cmpa    DSP_TXT_ROWS    ; skip if the current cursor row
F496  2D06                            blt     1f              ;   is less than the max rows
F498  7A0014                          dec     CSR_ROW         ; decrease the cursors row
F49B  BDF4A7                          jsr     std_text_scroll ; scroll the text up one line
F49E                  1       ; recalculate the cursor address based on CSR_ROW and CSR_COL
F49E  BDF4DD                          jsr     cursor_address  ; X = CSR_ADDR based on CSR_ROW and CSR_COL
F4A1  BF0011                          stx     CSR_ADDR        ; update CSR_ADDR 
F4A4  3512                            puls    a,x             ; restore the working registers
F4A6  39                              rts                     ; return from the line editor subroutine
                      
                      
                      
F4A7                  std_text_scroll ; scroll the standard text screen up one line
F4A7  3436                            pshs    d, x, y         ; store the working registers
F4A9  108E0400                        ldy     #STD_VID_MIN    ; Y = start of the standard video buffer
F4AD  F61C0A                          ldb     DSP_TXT_COLS    ; B = number of displayed text columns
                                      ;lslb                   ; B = B * 2 -- account for the attribute byte
F4B0  8E0400                          ldx     #STD_VID_MIN    ; X = start of the standard video buffer
                                      ; B can become negative in the 4x horizontal overscan modes
                                      ;       instead of shifting B left and using it to index once
                                      ;       simply load effective address twice
F4B3  3085                            leax    b,x             ; X = one line down
F4B5  3085                            leax    b,x             ; X = one line down
F4B7                  1       ; scroll up one line
F4B7  EC81                            ldd     ,x++            ; load character at X 
F4B9  EDA1                            std     ,y++            ; store it at Y
F4BB  BC1C00                          cmpx    STD_VID_MAX     ; at the end of the display?
F4BE  2DF7                            blt     1b              ; loop if not
                              ; fill the bottom line with spaces
F4C0  8E0400                          ldx     #STD_VID_MIN    ; X = start of the standard video buffer
F4C3  F61C0B                          ldb     DSP_TXT_ROWS    ; B = number of displayed rows
F4C6  5A                              decb                    ; B = B - 1  last line
F4C7  58                              lslb                    ; B = B * 1 -- account for the attribute byte
F4C8  B61C0A                          lda     DSP_TXT_COLS    ; A = number of displayed text columns
F4CB  3D                              mul                     ; D = A * B
F4CC  308B                            leax    d,x             ; X = the start of the bottom row
F4CE  8620                            lda     #$20            ; load up default space character
F4D0  F60015                          ldb     TXT_ATTR        ; and the default color
F4D3                  2       ; store the character with its color attribute
F4D3  ED81                            std     ,x++            ; store the space at X
F4D5  BC1C00                          cmpx    STD_VID_MAX     ; at the end of the text buffer
F4D8  2DF9                            blt     2b              ; loop if not
                              ; return
F4DA  3536                            puls    d,x,y           ; restore the working registers
F4DC  39                              rts
                      
                      
F4DD                  cursor_address  ; Update CSR_ADDR and return the cursor address in X 
                                      ; based on CSR_COL and CSR_ROW.
F4DD  3406                            pshs    d               ; store used registers
F4DF  8E0400                          ldx     #STD_VID_MIN    ; start of the standard video buffer
F4E2  B60014                          lda     CSR_ROW         ; A = current cursor row
F4E5  F61C0A                          ldb     DSP_TXT_COLS    ; B = number of columns displayed
F4E8  58                              lslb                    ; B = B * 2 -- account for the attribute byte
F4E9  3D                              mul                     ; D = A * B
F4EA  308B                            leax    d,x             ; X = D + X             
F4EC  F60013                          ldb     CSR_COL         ; B = current cursor column
F4EF  58                              lslb                    ; B = B * 2 -- account for the attribute byte
F4F0  3085                            leax    b,x             ; X = B + X
F4F2  BF0011                          stx     CSR_ADDR        ; store the cursor address
F4F5  3506                            puls    d               ; restore used registers
F4F7  39                              rts                     ; return
                      
                      
                      
                      
                      
