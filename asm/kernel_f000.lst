F306                  str_cmp_nmz     ; compare two null/space/"-terminated strings
                                      ;       on return:
                                      ;       A = tokenized command
                                      ;       X points to argument 1
                                      ;       Y points to argument 2
                                      ;       returns: compare condition in the Z and N condition flags
F306  3434                            pshs    B,X,Y           ; store the working registers
F308  8600                            lda     #0              ; clear the token flag
F30A  3402                            pshs    A               ;       and store it locally @ 0,S
F30C                  str_cmp_loop    ; is the string 1 character a terminator?
F30C  A684                            lda     ,x              ; fetch a character from the first string
F30E  2726                            beq     str1_cmp_term   ; is a null-terminator? verify other string
F310  8120                            cmpa    #' '            ; is it a space character?
F312  2722                            beq     str1_cmp_term   ; branch to verify other strings termination
F314  8122                            cmpa    #'"'            ; is it a double quote?
F316  271E                            beq     str1_cmp_term   ; branch to verify other strings termination
F318  810D                            cmpa    #$0d            ; is it an ENTER character?
F31A  271A                            beq     str1_cmp_term   ; branch to verify other strings termination
                                      ; is the string 2 character a terminator?
F31C  E6A4                            ldb     ,y              ; fetch a character from the second string
F31E  2728                            beq     str2_cmp_term   ; is a null-terminator? verify other string
F320  C120                            cmpb    #' '            ; is it a space character?
F322  2724                            beq     str2_cmp_term   ; branch to verify other strings termination
F324  C122                            cmpb    #'"'            ; is it a double-quote character?
F326  2720                            beq     str2_cmp_term   ; branch to verify other strings termination
F328  C10D                            cmpb    #$0d            ; is it an ENTER character?
F32A  271C                            beq     str2_cmp_term   ; branch to verify other strings termination
F32C                  str_cmp_equal   ; are characters are same, loop
F32C  8A20                            ora     #$20            ; A to lowercase
F32E  3001                            leax    1,x             ; increment X
F330  A1A0                            cmpa    ,y+             ; compare characters and increment Y
F332  27D8                            beq     str_cmp_loop    ; loop if characters are equal
F334  2024                            bra     str_cmp_differ  ; loop finished, not equal
F336                  str1_cmp_term   ; string 1 has terminated, check string 2 termination
F336  E6A4                            ldb     ,y              ; load a character from the second string
F338  2724                            beq     str_cmp_done    ; is it a null-terminator? strings are equal
F33A  C120                            cmpb    #' '            ; is it a SPACE terminator?
F33C  2720                            beq     str_cmp_done    ;       strings are equal
F33E  C122                            cmpb    #'"'            ; is it a double-quote terminator?
F340  271C                            beq     str_cmp_done    ;       strings are equal
F342  C10D                            cmpb    #$0d            ; is it an ENTER terminator?
F344  2718                            beq     str_cmp_done    ;       strings are equal
F346  2012                            bra     str_cmp_differ  ; otherwise, strings are different
F348                  str2_cmp_term   ; string 2 has terminated, check string 1 for termination
F348  A684                            lda     ,x              ; load a character from the first string
F34A  2712                            beq     str_cmp_done    ; is it a null-terminator? strings are equal
F34C  8120                            cmpa    #' '            ; is it SPACE terminator?
F34E  270E                            beq     str_cmp_done    ;       strings are equal
F350  8122                            cmpa    #'"'            ; is it a double-space terminator?
F352  270A                            beq     str_cmp_done    ;       strings are equal
F354  810D                            cmpa    #$0d            ; is it an ENTER terminator?
F356  2706                            beq     str_cmp_done    ;       strings are equal
F358  2000                            bra     str_cmp_differ  ; otherwise, strings are different
                                      ; characters differ, drop out
