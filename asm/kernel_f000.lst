                      ; ***********************************************************************
                      ; *     kernel_f000.asm                                                 *
                      ; *                                                                     *
                      ; *     a.k.a. The Basic Input and Output System (BIOS)                 *
                      ; ***********************************************************************
                      ; *                                                                     *
                      ; *     LINUX:          ./asm/build.sh asm/kernel_f000                  *
                      ; *             or                                                      *       
                      ; *     WINDOWS:        asm kernel_f000                                 *
                      ; *                                                                     *
                      ; *     build.sh:                                                       *
                      ; *             #!/bin/bash                                             *
                      ; *             #lwasm -9 test.asm --format=ihex -otest.hex -ltest.lst  *
                      ; *             echo "lwasm -9 $1.asm --format=ihex -o$1.hex -l$1.lst"  *
                      ; *             lwasm -9 $1.asm --format=ihex -o$1.hex -l$1.lst         *
                      ; *                                                                     *
                      ; *     asm.bat:                                                        *
                      ; *             @set arg1=%1                                            *
                      ; *             asm6809 -H -9 %arg1%.asm -o %arg1%.hex -l %arg1%.lst    *
                      ; ***********************************************************************
0000                                  INCLUDE "memory_map.asm"
                      ;  **********************************************
                      ;  * Allocated 64k Memory Mapped System Symbols *
                      ;  **********************************************
0000                  SOFT_VECTORS    equ   $0000
                      
                                ; Software Interrupt Vectors:
0000                  SOFT_RSRVD      equ   $0000    ; Motorola RESERVED Software Interrupt Vector
0002                  SOFT_SWI3       equ   $0002    ; SWI3 Software Interrupt Vector
0004                  SOFT_SWI2       equ   $0004    ; SWI2 Software Interrupt Vector
0006                  SOFT_FIRQ       equ   $0006    ; FIRQ Software Interrupt Vector
0008                  SOFT_IRQ        equ   $0008    ; IRQ Software Interrupt Vector
000A                  SOFT_SWI        equ   $000A    ; SWI / SYS Software Interrupt Vector
000C                  SOFT_NMI        equ   $000C    ; NMI Software Interrupt Vector
000E                  SOFT_RESET      equ   $000E    ; RESET Software Interrupt Vector
                      
0010                  ZERO_PAGE       equ   $0010
0100                  USER_STACK      equ   $0100
0200                  USTACK_TOP      equ   $0200    ; Top of the user stack space
0200                  SYSTEM_STACK    equ   $0200
0400                  SSTACK_TOP      equ   $0400    ; Top of the system stack space
                      
                                ; Display Buffer
0400                  SCREEN_BUFFER    equ   $0400
                      
                                ; Device Registers:
1C00                  HDW_REGS        equ   $1C00    ; Begin Device Hardware Registers
                      
1C00                  STD_VID_MAX     equ   $1C00    ;  (Word) Standard Video Buffer Max
                      
1C02                  SYS_STATE       equ   $1C02    ;  (Byte) System State Register
                                ; SYS_STATE: ABCD.SSSS
                                ;      A:0   = Error: Standard Buffer Overflow
                                ;      B:0   = Error: Extended Buffer Overflow
                                ;      C:0   = Error: Reserved
                                ;      D:0   = Error: Reserved
                                ;      S:$0  = CPU Clock  25 khz.
                                ;      S:$1  = CPU Clock  50 khz.
                                ;      S:$2  = CPU Clock 100 khz.
                                ;      S:$3  = CPU Clock 200 khz.
                                ;      S:$4  = CPU Clock 333 khz.
                                ;      S:$5  = CPU Clock 416 khz.
                                ;      S:$6  = CPU Clock 500 khz.
                                ;      S:$7  = CPU Clock 625 khz.
                                ;      S:$8  = CPU Clock 769 khz.
                                ;      S:$9  = CPU Clock 833 khz.
                                ;      S:$A  = CPU Clock 1.0 mhz.
                                ;      S:$B  = CPU Clock 1.4 mhz.
                                ;      S:$C  = CPU Clock 2.0 mhz.
                                ;      S:$D  = CPU Clock 3.3 mhz.
                                ;      S:$E  = CPU Clock 5.0 mhz.
                                ;      S:$F  = CPU Clock ~10.0 mhz. (unmetered)
                      
1C03                  SYS_SPEED       equ   $1C03    ;  (Word) Approx. Average CPU Clock Speed
                      
1C05                  SYS_CLOCK_DIV    equ   $1C05    ;  (Byte) 60 hz Clock Divider Register (Read Only)
                                ; SYS_CLOCK_DIV: ABCD.SSSS
                                ;      bit 7: 0.46875 hz
                                ;      bit 6: 0.9375 hz
                                ;      bit 5: 1.875 hz
                                ;      bit 4: 3.75 hz
                                ;      bit 3: 7.5 hz
                                ;      bit 2: 15.0 hz
                                ;      bit 1: 30.0 hz
                                ;      bit 0: 60.0 hz
                      
1C06                  SYS_TIMER       equ   $1C06    ;  (Word) Increments at 0.46875 hz
                      
1C08                  DSP_GRES        equ   $1C08    ;  (Byte) Screen Resolution Register
                                ; DSP_GRES: BBRR.HHVV
                                ;     BB:00 = Standard Graphics 1-bpp (2-color mode)
                                ;     BB:01 = Standard Graphics 2-bpp (4-color mode)
                                ;     BB:10 = Standard Graphics 4-bpp (16-color mode)
                                ;     BB:11 = Standard Graphics 8-bpp (256-color mode)
                                ;     RR:00 = 16:9  aspect (1.777778)
                                ;     RR:01 = 16:10 aspect (1.600000)
                                ;     RR:10 = 16:11 aspect (1.454545)
                                ;     RR:11 = 16:12 aspect (1.333333)
                                ;     HH:00 = 4x Horizontal Overscan Multiplier
                                ;     HH:01 = 3x Horizontal Overscan Multiplier
                                ;     HH:10 = 2x Horizontal Overscan Multiplier
                                ;     HH:11 = 1x Horizontal Overscan Multiplier
                                ;     VV:00 = 4x Vertical Overscan Multiplier
                                ;     VV:01 = 3x Vertical Overscan Multiplier
                                ;     VV:10 = 2x Vertical Overscan Multiplier
                                ;     VV:11 = 1x Vertical Overscan Multiplier
                      
1C09                  DSP_EXT         equ   $1C09    ;  (Byte) Extended Graphics Register
                                ; DSP_EXT: ABCD.EFGG
                                ;      AA:00 = Extended Graphics 1bpp (2-color mode)
                                ;      AA:01 = Extended Graphics 2bpp (4-color mode)
                                ;      AA:10 = Extended Graphics 4bpp (16-color mode)
                                ;      AA:11 = Extended Graphics 4bpp (16-color mode)
                                ;      B:0   = Extended Graphics: DISABLED
                                ;      B:1   = Extended Graphics: ENABLED
                                ;      C:0   = Extended Extended Mode: BITMAP
                                ;      C:1   = Extended Extended Mode: TILES
                                ;      D:0   = Standard Graphics: DISABLED
                                ;      D:1   = Standard Graphics: ENABLED
                                ;      E:0   = Standard Display Mode: TEXT
                                ;      E:1   = Standard Display Mode: BITMAP
                                ;      F:0   = VSYNC OFF
                                ;      F:1   = VSYNC ON
                                ;      B:0   = Fullscreen Enabled( emulator only )
                                ;      B:1   = Windowed Enabled ( emulator only )
                      
1C0A                  DSP_TXT_COLS    equ   $1C0A    ;  (Byte) READ-ONLY Text Screen Columns
1C0B                  DSP_TXT_ROWS    equ   $1C0B    ;  (Byte) READ-ONLY Text Screens Rows
                      
1C0C                  DSP_PAL_IDX     equ   $1C0C    ;  (Byte) Color Palette Index
                                ; DSP_PAL_IDX: 0-255
                                ; Note: Use this register to set the index into theColor Palette.
                                ;   Set this value prior referencing color data (DSP_PAL_CLR).
                      
1C0D                  DSP_PAL_CLR     equ   $1C0D    ;  (Word) Indexed Color Palette Data
                                ; DSP_PAL_CLR: Color Data A4R4G4B4 format
                                ; Note: This is the color data for an individual palette entry.
                                ;     Write to DSP_PAL_IDX with the index within the color palette
                                ;     prior to reading or writing the color data in the DSP_PAL_CLR register.
                      
1C0F                  DSP_GLYPH_IDX    equ   $1C0F    ;  (Byte) Text Glyph Index
                                ; DSP_GLYPH_IDX: 0-256
                                ; Note: Set this register to index a specific text glyph. Set this value
                                ;     prior to updating glyph pixel data.
                      
1C10                  DSP_GLYPH_DATA    equ   $1C10    ;  (8-Bytes) Text Glyph Pixel Data Array
                                ; DSP_GLYPH_DATA: 8 rows of binary encoded glyph pixel data
                                ; Note: Each 8x8 text glyph is composed of 8 bytes. The first byte in this
                                ;     array represents the top line of 8 pixels. Each array entry represents
                                ;     a row of 8 pixels.
                      
                                ; Debug Hardware Registers:
1C18                  DBG_BEGIN       equ   $1C18    ;  start of mouse cursor hardware registers
1C18                  DBG_TEMP        equ   $1C18    ;  (Byte) Simple Debug test register
1C19                  DBG_END         equ   $1C19    ; End Debug Registers
                      
                                ; Mouse Cursor Hardware Registers:
1C19                  CSR_BEGIN       equ   $1C19    ;  start of mouse cursor hardware registers
1C19                  CSR_XPOS        equ   $1C19    ;  (Word) horizontal mouse cursor coordinate
1C1B                  CSR_YPOS        equ   $1C1B    ;  (Word) vertical mouse cursor coordinate
1C1D                  CSR_XOFS        equ   $1C1D    ;  (Byte) horizontal mouse cursor offset
1C1E                  CSR_YOFS        equ   $1C1E    ;  (Byte) vertical mouse cursor offset
1C1F                  CSR_SCROLL      equ   $1C1F    ;  (Signed) MouseWheel Scroll: -1, 0, 1
1C20                  CSR_FLAGS       equ   $1C20    ;  (Byte) mouse button flags:
                                ;  CSR_FLAGS:
                                ;       bits 0-5: button states
                                ;       bits 6-7: number of clicks
1C21                  CSR_BMP_INDX    equ   $1C21    ;  (Byte) mouse cursor bitmap pixel offset
1C22                  CSR_BMP_DATA    equ   $1C22    ;  (Byte) mouse cursor bitmap pixel index color
1C24                  CSR_PAL_INDX    equ   $1C24    ;  (Byte) mouse cursor color palette index (0-15)
1C25                  CSR_PAL_DATA    equ   $1C25    ;  (Word) mouse cursor color palette data RGBA4444
1C27                  CSR_END         equ   $1C27    ; End Mouse Registers
1C27                  GFX_END         equ   $1C27    ; End of GFX Device Registers
                      
1C27                  KEY_BEGIN       equ   $1C27    ; Start of the Keyboard Register space
1C27                  CHAR_Q_LEN      equ   $1C27    ;   (Byte) # of characters waiting in queue        (Read Only)
1C28                  CHAR_SCAN       equ   $1C28    ;   (Byte) read next character in queue (not popped when read)
1C29                  CHAR_POP        equ   $1C29    ;   (Byte) read next character in queue (not popped when read)
1C2A                  XKEY_BUFFER     equ   $1C2A    ;   (128 bits) 16 bytes for XK_KEY data buffer     (Read Only)
1C3A                  EDT_BFR_CSR     equ   $1C3A    ;   (Byte) cursor position within edit buffer     (Read/Write)
1C3B                  EDT_ENABLE      equ   $1C3B    ;   (Byte) line editor enable flag     (Read/Write)
1C3C                  EDT_BUFFER      equ   $1C3C    ;   line editing character buffer                 (Read/Write)
1C7C                  KEY_END         equ   $1C7C    ; End of the Keyboard Register space
                      
                          ; 4996 ($1384) bytes remaining for additional registers.
1C7C                  RESERVED        equ   $1C7C
                      
                                ; User RAM (32K)
3000                  USER_RAM        equ   $3000
                      
                                ; Paged RAM (8K)
B000                  PAGED_RAM       equ   $B000
                      
                                ; PAGED ROM (8K bytes)
D000                  PAGED_ROM       equ   $D000
                      
                                ; KERNEL ROM (4K bytes)
F000                  KERNEL_ROM      equ   $F000
                      
                                ; Hardware Interrupt Vectors:
FFF0                  HARD_RSRVD      equ   $FFF0    ; Motorola RESERVED Hardware Interrupt Vector
FFF2                  HARD_SWI3       equ   $FFF2    ; SWI3 Hardware Interrupt Vector
FFF4                  HARD_SWI2       equ   $FFF4    ; SWI2 Hardware Interrupt Vector
FFF6                  HARD_FIRQ       equ   $FFF6    ; FIRQ Hardware Interrupt Vector
FFF8                  HARD_IRQ        equ   $FFF8    ; IRQ Hardware Interrupt Vector
FFFA                  HARD_SWI        equ   $FFFA    ; SWI / SYS Hardware Interrupt Vector
FFFC                  HARD_NMI        equ   $FFFC    ; NMI Hardware Interrupt Vector
FFFE                  HARD_RESET      equ   $FFFE    ; RESET Hardware Interrupt Vector
                      ; END of definitions
                      
                      
                      ; Software Vectors
0000                          org     $0000   
0000  F022            VECT_RSRVD      fdb     RSRVD_start     ; This will likely be used as the EXEC vector
0002  F024            VECT_SWI3       fdb     SWI3_start      ; SWI3 Software Interrupt Vector
0004  F026            VECT_SWI2       fdb     SWI2_start      ; SWI2 Software Interrupt Vector
0006  F028            VECT_FIRQ       fdb     FIRQ_start      ; FIRQ Software Interrupt Vector
0008  F02A            VECT_IRQ        fdb     IRQ_start       ; IRQ Software Interrupt Vector
000A  F02C            VECT_SWI        fdb     SWI_start       ; SWI / SYS Software Interrupt Vector
000C  F02E            VECT_NMI        fdb     NMI_start       ; NMI Software Interrupt Vector 
000E  F032            VECT_RESET      fdb     kernel_start    ; RESET Software Interrupt Vecto        
                      
                      ; kernel call vectors
                      ;CHROUT_VECT    fdb     char_out_main   ; CHROUT Software Vector
                              
                      
                      ; system zero-page variables
0010  B4              CSR_ATTR        fcb     $B4;            ; current cursor attribute
0011  0000            CSR_ADDR        fdb     $0000;          ; current cursor address in screen memory
0013  00              CSR_COL         fcb     $00;            ; current cursor column
0014  00              CSR_ROW         fcb     $00;            ; current cursor row
0015  B4              TXT_ATTR        fcb     $B4             ; current text color attribute
0016  0000            EDLIN_ANCH      fdb     $0000;          ; line edit text anchor address
0018  00              var1            fcb     0;
0019  00              var2            fcb     0;
                      
                      
                      
                      
                      ; Kernel Jump Vector Calls      
F000                          org     KERNEL_ROM              
F000  6E9F0000        KRNL_RSRVD      jmp     [VECT_RSRVD]    ; This will likely be used as t he EXEC vector
F004  6E9F0002        KRNL_SWI3       jmp     [VECT_SWI3 ]    ; SWI3 Software Interrupt Vector        
F008  6E9F0004        KRNL_SWI2       jmp     [VECT_SWI2 ]    ; SWI2 Software Interrupt Vector
F00C  6E9F0006        KRNL_FIRQ       jmp     [VECT_FIRQ ]    ; FIRQ Software Interrupt Vector
F010  6E9F0008        KRNL_IRQ        jmp     [VECT_IRQ  ]    ; IRQ Software Interrupt Vector
F014  6E9F000A        KRNL_SWI        jmp     [VECT_SWI  ]    ; SWI / SYS Software Interrupt Vector
F018  6E9F000C        KRNL_NMI        jmp     [VECT_NMI  ]    ; NMI Software Interrupt Vector
F01C  6E9F000E        KRNL_RESET      jmp     [VECT_RESET]    ; RESET Software Interrupt Vector       
                      
                      ; a null vectors (i.e. an infinate loop traps for vector testing)
F020  20FE            KRNL_UNDEF      bra     KRNL_UNDEF
                      
F022  20FE            RSRVD_start     bra     RSRVD_start     ; EXEC program
F024  20FE            SWI3_start      bra     SWI3_start      ; SWI3 Implementation
F026  20FE            SWI2_start      bra     SWI2_start      ; SWI2 Implementation
F028  20FE            FIRQ_start      bra     FIRQ_start      ; FIRQ Implementation
F02A  20FE            IRQ_start       bra     IRQ_start       ; IRQ Implementation
F02C  20FE            SWI_start       bra     SWI_start       ; SWI / SYS Implementation
F02E  20FE            NMI_start       bra     NMI_start       ; NMI Implementation
F030  20FE            RESET_start     bra     RESET_start     ; RESET Implementation
                      
                      
F032                  kernel_start
                              ; initialize both stack pointers
F032  10CE0400                        lds     #SSTACK_TOP
F036  CE0200                          ldu     #USTACK_TOP
                      
                      ; SYS_STATE: ABCD.SSSS
                      ;      A:0   = Error: Standard Buffer Overflow
                      ;      B:0   = Error: Extended Buffer Overflow
                      ;      C:0   = Error: Reserved
                      ;      D:0   = Error: Reserved
                      ;      S:$0  = CPU Clock  25 khz.
                      ;      S:$1  = CPU Clock  50 khz.
                      ;      S:$2  = CPU Clock 100 khz.
                      ;      S:$3  = CPU Clock 200 khz.
                      ;      S:$4  = CPU Clock 333 khz.
                      ;      S:$5  = CPU Clock 416 khz.
                      ;      S:$6  = CPU Clock 500 khz.
                      ;      S:$7  = CPU Clock 625 khz.
                      ;      S:$8  = CPU Clock 769 khz.
                      ;      S:$9  = CPU Clock 833 khz.
                      ;      S:$A  = CPU Clock 1.0 mhz.
                      ;      S:$B  = CPU Clock 1.4 mhz.
                      ;      S:$C  = CPU Clock 2.0 mhz.
                      ;      S:$D  = CPU Clock 3.3 mhz.
                      ;      S:$E  = CPU Clock 5.0 mhz.
                      ;      S:$F  = CPU Clock ~10.0 mhz. (unmetered)
F039  860A                            lda     #$0A
F03B  B71C02                          sta     SYS_STATE
                      
                      ;       DSP_GRES: BBRR.HHVV
                      ;           BB:00 = Standard Graphics 1-bpp (2-color mode)      
                      ;           BB:01 = Standard Graphics 2-bpp (4-color mode)      
                      ;           BB:10 = Standard Graphics 4-bpp (16-color mode)     
                      ;           BB:11 = Standard Graphics 8-bpp (256-color mode)    
                      ;           RR:00 = 16 / 9      Aspect:
                      ;           RR:01 = 16 / 10     Aspect:
                      ;           RR:10 = 16 / 11     Aspect:
                      ;           RR:11 = 16 / 12     Aspect:
                      ;           HH:00 = 4x Horizontal Overscan Multiplier
                      ;           HH:01 = 3x Horizontal Overscan Multiplier
                      ;           HH:10 = 2x Horizontal Overscan Multiplier
                      ;           HH:11 = 1x Horizontal Overscan Multiplier
                      ;           VV:00 = 4x Vertical Overscan Multiplier
                      ;           VV:01 = 3x Vertical Overscan Multiplier
                      ;           VV:10 = 2x Vertical Overscan Multiplier
                      ;           VV:11 = 1x Vertical Overscan Multiplier
F03E  86CA                            lda     #$CA
F040  B71C08                          sta     DSP_GRES
                      
                      ; DSP_EXT: ABCD.EFGG
                      ;      AA:00 = Extended Graphics 1bpp (2-color mode)
                      ;      AA:01 = Extended Graphics 2bpp (4-color mode)
                      ;      AA:10 = Extended Graphics 4bpp (16-color mode)
                      ;      AA:11 = Extended Graphics 4bpp (16-color mode)
                      ;      B:0   = Extended Graphics: DISABLED
                      ;      B:1   = Extended Graphics: ENABLED
                      ;      C:0   = Extended Extended Mode: BITMAP
                      ;      C:1   = Extended Extended Mode: TILES
                      ;      D:0   = Standard Graphics: DISABLED
                      ;      D:1   = Standard Graphics: ENABLED
                      ;      E:0   = Standard Display Mode: TEXT
                      ;      E:1   = Standard Display Mode: BITMAP
                      ;      F:0   = VSYNC OFF
                      ;      F:1   = VSYNC ON
                      ;      B:0   = Fullscreen Enabled( emulator only )
                      ;      B:1   = Windowed Enabled ( emulator only )
F043  86C9                            lda     #$C9
F045  B71C09                          sta     DSP_EXT
                      
                              ; begin the display
F048  BDF152                          jsr     cls
F04B  8EFE00                          ldx     #prompt0                
F04E  BDF107                          jsr     line_out        
F051  8EFE11                          ldx     #prompt1
F054  BDF107                          jsr     line_out        
F057  8EFE34                          ldx     #ready_prompt           
F05A  BDF107                          jsr     line_out        
F05D                  1
F05D  BDF062                          jsr     line_edit
F060  20FB                            bra     1b
                      
                      ;       ; infinite loop
                      ;inf_loop       bra     inf_loop
                      
                      
                      ; output the line edit buffer
F062                  line_edit
F062  86FF                            lda     #$ff            ; 'true'
F064  B71C3B                          sta     EDT_ENABLE      ; enable the hardware line editor sub-system
F067  7F1C3C                          clr     EDT_BUFFER      ; null the start of the edit buffer
F06A  FC0011                          ldd     CSR_ADDR        ; fetch the current cursor address
F06D  FD0016                          std     EDLIN_ANCH      ; store it as the anchor
F070                  6       ; check for ENTER press
F070  B61C28                          lda     CHAR_SCAN       ; scan for a character waiting in the queue
F073  810D                            cmpa    #$0d            ; is it the ENTER key?
F075  2628                            bne     0f              ; nope, continue to render the text line editor
F077  B61C29                          lda     CHAR_POP        ; pop the ENTER from the queue before returning
F07A  CC20B4                          ldd     #$20b4          ; load a colored space
F07D  ED9F0011                        std     [CSR_ADDR]      ; overrite the last colored cursor
                                      ; home the cursor
F081  7F0013                          clr     CSR_COL         ; CSR_COL = 0
F084  7C0014                          inc     CSR_ROW         ; CSR_ROW = 0
F087  B60014                          lda     CSR_ROW         ; A - CSR_ROW
F08A  B11C0B                          cmpa    DSP_TXT_ROWS    ; last line?
F08D  2D06                            blt     7f              ; nope, recalc the new cursor address
F08F  7A0014                          dec     CSR_ROW         ; decrement CSR_ROW
F092  BDF18E                          jsr     std_text_scroll ; scroll the text buffer
F095                  7       ; recalculate the cursor address based on CSR_ROW and CSR_COL
F095  BDF1C3                          jsr     cursor_address  ; find CSR_ADDR based on CSR_ROW and CSR_COL
F098  BF0011                          stx     CSR_ADDR        ; store the new CSR_ADDR
F09B  7F1C3B                          clr     EDT_ENABLE      ; disable the hardware line editor sub-system
F09E  39                              rts                     ; return from the line editor subroutine
F09F                  0       ; begin the line edit routine
                                      ; ldu   #SCREEN_BUFFER  ; reserve the start of the display buffer
                                      ; ldu   EDLIN_ANCH      ; reserve the start of the display buffer
F09F  108E1C3C                        ldy     #EDT_BUFFER     ; start of the character line edit buffer
                                      ; ldx   #SCREEN_BUFFER  ; point to the start of the display buffer
F0A3  BE0016                          ldx     EDLIN_ANCH      ; point to the start of the display buffer
F0A6  B61C3A                          lda     EDT_BFR_CSR     ; fetch the cursor position
F0A9  3402                            pshs    a               ; save it on the stack as a local variable      
F0AB  2604                            bne     1f              ; cursor position is not zero, begin text
F0AD  A6A4                            lda     ,y              ; load the first character in the buffer
F0AF  261D                            bne     4f              ; if its not zero, display the cursor
F0B1                  1       ; start of the line
F0B1  B61C3A                          lda     EDT_BFR_CSR     ; load the cursor position
F0B4  270E                            beq     3f              ; if theres no character, display the cursor
F0B6                  2       ; display up to the cursor position
F0B6  A6A0                            lda     ,y+             ; fetch a character from the edit buffer
F0B8  270A                            beq     3f              ; null character (end of line)
F0BA  C6B4                            ldb     #$B4            ; color attribute
F0BC  ED81                            std     ,x++            ; display the character with its color  
F0BE  6AE4                            dec     0,s             ; decrease the local cursor position
F0C0  270C                            beq     4f              ; brach if the cursor is over a character
F0C2  20F2                            bra     2b              ; continue displaying characters
F0C4                  3       ; cursor at end of the line
F0C4  3502                            puls    a               ; repair the stack
F0C6  8620                            lda     #$20            ; load a space
F0C8  A781                            sta     ,x++            ; display the space
F0CA  8D14                            bsr     flash_the_cursor        
F0CC  20A2                            bra     6b              ; loop and display changes in the edit buffer
F0CE                  4       ; cursor over a character
F0CE  3502                            puls    a               ; clean up the stack
F0D0  A6A0                            lda     ,y+             ; load the next character from the buffer
F0D2  A781                            sta     ,x++            ; ignore the attribute
                              ; flash the cursor
F0D4  8D0A                            bsr     flash_the_cursor
F0D6                  5       ; finish the line
F0D6  A6A0                            lda     ,y+             ; load the next character from the buffer
F0D8  2796                            beq     6b              ; loop back to the top if done
F0DA  C6B4                            ldb     #$b4            ; load the basic screen attribute
F0DC  ED81                            std     ,x++            ; display the next character with its color
F0DE  20F6                            bra     5b              ; continue until the line is finished
                      
F0E0                  flash_the_cursor
F0E0  3456                            pshs    a,b,x,u         ; save these on the stack
F0E2  FE0016                          ldu     EDLIN_ANCH      ; point to the edline start of line anchor
F0E5  B61C07                          lda     SYS_TIMER+1     ; load the LSB of the system timer
F0E8  8407                            anda    #$07            ; only concerned with these bits
F0EA  2618                            bne     1f              ; if non-zero, skip color change
F0EC  B60010                          lda     CSR_ATTR        ; load the next cursor color
F0EF  4C                              inca                    ; increment it
F0F0  840F                            anda    #$0f            ; mask off the foreground color
F0F2  8AF0                            ora     #$f0            ; foreground 15 = opaque black
F0F4  B70010                          sta     CSR_ATTR        ; store the new attribute
F0F7  F61C3A                          ldb     EDT_BFR_CSR     ; load the cursor position
F0FA  58                              lslb                    ; skip the attribue
F0FB  5C                              incb                    ; increment the attribute color
F0FC  A7C5                            sta     b, u            ; update the characters color
F0FE  5A                              decb                    ; now index the character
F0FF  33C5                            leau    b,u             ; load that characters address
F101  FF0011                          stu     CSR_ADDR        ; store it on the zero-page
F104                  1       ; clean up and return   
F104  3556                            puls    a,b,x,u         ; pop these off the stack
F106  39                              rts                     ; return when done
                      
                      
F107                  line_out        ; Display a null terminated string pointed to by X
                                      ; begining at CSR_ROW and CSR_COL.
F107  3412                            pshs    a,x             ; store the working registers
F109                  1       ; line out main loop
F109  A680                            lda     ,x+             ; load the next character to display
F10B  2707                            beq     2f              ; skip if at null-terminator
F10D  2B05                            bmi     2f              ; skip if high bit is set
F10F  BDF117                          jsr     char_out        ; output this character
F112  20F5                            bra     1b              
F114                  2       ; clean up and return
F114  3512                            puls    a,x             ; restore the working registers
F116  39                              rts                     ; return from subroutine
                      
                      
                      
F117                  char_out        ; output a formatted text character based on A
                                      ; jsr   [CHROUT_VECT]
F117                  char_out_main   ; the main CHROUT routine
F117  3416                            pshs    d,x
                      
F119  8120                            cmpa    #$20            ; is a printable character $20 - $ff
F11B  2C09                            bge     1f              ; yup, go print it
F11D  810A                            cmpa    #$0a            ; line feed ?
F11F  2603                            bne     2f              ; no, skip to next
F121  BDF16F                          jsr     csr_new_line    ; perform a new line
F124                  2       ; skip to end
F124  2029                            bra     0f              ; just skip everything
F126                  1       ; output a printable character $20 - $ff
F126  BDF1C3                          jsr     cursor_address  ; X = CSR_ADDR          
F129  F60015                          ldb     TXT_ATTR        ; fetch the default color attribute
F12C  ED84                            std     ,x              ; store it on screen
F12E  7C0013                          inc     CSR_COL         ; increase the cursors column
                                      ; handle line wrap and scrolling
F131  B60013                          lda     CSR_COL         ; load cursor column
F134  B11C0A                          cmpa    DSP_TXT_COLS    ; compare with max displayed columns
F137  2C02                            bge     1f              ; if greater or equal
F139  2014                            bra     0f              ; skip and return
F13B                  1       ; if (CSR_COL >= DSP_TXT_COLS)
F13B  7F0013                          clr     CSR_COL         ; clear CSR_COL
F13E  7C0014                          inc     CSR_ROW         ; increment CSR_ROW
F141  B60014                          lda     CSR_ROW         ; load CSR_ROWS
F144  B11C0B                          cmpa    DSP_TXT_ROWS    ; if (CSR_ROW < DSP_TXT_ROWS)
F147  2D06                            blt     0f              ;       clean up and return
F149  BDF18E                          jsr     std_text_scroll ; scroll the text screen
F14C  7A0014                          dec     CSR_ROW         ; CSR_ROW--
F14F                  0       ; clean up and return
F14F  3516                            puls    d,x             ; restore the working registers
F151  39                              rts                     ; return
                      
                              
F152                  cls     ; clear out the text buffer     
F152  3416                            pshs    d, x            ; store the working registers
F154  7F0013                          clr     CSR_COL         ; cursor column = 0
F157  7F0014                          clr     CSR_ROW         ; cursor row = 0
F15A  BDF1C3                          jsr     cursor_address  ; X = cursor address based on CSR_COL and CSR_ROW
F15D  8E0400                          ldx     #SCREEN_BUFFER  ; point to the start of the text buffer
F160  8620                            lda     #$20            ; set next character to space
F162  F60015                          ldb     TXT_ATTR        ; load the characters color
F165                  1       ; cls main loop 
F165  ED81                            std     ,x++            ; store the space with its color attribute
F167  8C1C00                          cmpx    #STD_VID_MAX    ; are we at the end of the text buffer?
F16A  2DF9                            blt     1b              ;       loop if not
F16C  3516                            puls    d, x            ; restore the working registers
F16E  39                              rts                     ; return
                      
                      
F16F                  csr_new_line    ; perform a line-feed and a carriage return with scrolling
F16F  3412                            pshs    a, x            ; store the working registers
F171  7F0013                          clr     CSR_COL         ; set cursor column to zero
F174  7C0014                          inc     CSR_ROW         ; increment the cursor row
F177  B60014                          lda     CSR_ROW         ; A = cursor row
F17A  B11C0B                          cmpa    DSP_TXT_ROWS    ; skip if the current cursor row
F17D  2D06                            blt     1f              ;   is less than the max rows
F17F  7A0014                          dec     CSR_ROW         ; decrease the cursors row
F182  BDF18E                          jsr     std_text_scroll ; scroll the text up one line
F185                  1       ; recalculate the cursor address based on CSR_ROW and CSR_COL
F185  BDF1C3                          jsr     cursor_address  ; X = CSR_ADDR based on CSR_ROW and CSR_COL
F188  BF0011                          stx     CSR_ADDR        ; update CSR_ADDR 
F18B  3512                            puls    a,x             ; restore the working registers
F18D  39                              rts                     ; return from the line editor subroutine
                      
                      
                      
F18E                  std_text_scroll ; scroll the standard text screen up one line
F18E  3436                            pshs    d, x, y         ; store the working registers
F190  108E0400                        ldy     #SCREEN_BUFFER  ; Y = start of the standard video buffer
F194  F61C0A                          ldb     DSP_TXT_COLS    ; B = number of displayed text columns
F197  58                              lslb                    ; B = B * 2 -- account for the attribute byte
F198  8E0400                          ldx     #SCREEN_BUFFER  ; X = start of the standard video buffer
F19B  3085                            leax    b,x             ; X = one line down
F19D                  1       ; scroll up one line
F19D  EC81                            ldd     ,x++            ; load character at X 
F19F  EDA1                            std     ,y++            ; store it at Y
F1A1  BC1C00                          cmpx    STD_VID_MAX     ; at the end of the display?
F1A4  2DF7                            blt     1b              ; loop if not
                              ; fill the bottom line with spaces
F1A6  8E0400                          ldx     #SCREEN_BUFFER  ; X = start of the standard video buffer
F1A9  F61C0B                          ldb     DSP_TXT_ROWS    ; B = number of displayed rows
F1AC  5A                              decb                    ; B = B - 1  last line
F1AD  58                              lslb                    ; B = B * 1 -- account for the attribute byte
F1AE  B61C0A                          lda     DSP_TXT_COLS    ; A = number of displayed text columns
F1B1  3D                              mul                     ; D = A * B
F1B2  308B                            leax    d,x             ; X = the start of the bottom row
F1B4  8620                            lda     #$20            ; load up default space character
F1B6  F60015                          ldb     TXT_ATTR        ; and the default color
F1B9                  2       ; store the character with its color attribute
F1B9  ED81                            std     ,x++            ; store the space at X
F1BB  BC1C00                          cmpx    STD_VID_MAX     ; at the end of the text buffer
F1BE  2DF9                            blt     2b              ; loop if not
                              ; return
F1C0  3536                            puls    d,x,y           ; restore the working registers
F1C2  39                              rts
                      
                      
F1C3                  cursor_address  ; Update CSR_ADDR and return the cursor address in X 
                                      ; based on CSR_COL and CSR_ROW.
F1C3  3406                            pshs    d               ; store used registers
F1C5  8E0400                          ldx     #SCREEN_BUFFER  ; start of the standard video buffer
F1C8  B60014                          lda     CSR_ROW         ; A = current cursor row
F1CB  F61C0A                          ldb     DSP_TXT_COLS    ; B = number of columns displayed
F1CE  58                              lslb                    ; B = B * 2 -- account for the attribute byte
F1CF  3D                              mul                     ; D = A * B
F1D0  308B                            leax    d,x             ; X = D + X             
F1D2  F60013                          ldb     CSR_COL         ; B = current cursor column
F1D5  58                              lslb                    ; B = B * 2 -- account for the attribute byte
F1D6  3085                            leax    b,x             ; X = B + X
F1D8  BF0011                          stx     CSR_ADDR        ; store the cursor address
F1DB  3506                            puls    d               ; restore used registers
F1DD  39                              rts                     ; return
                      
                      
                      
                      
                      
