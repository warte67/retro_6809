     000A             (   memory_map.asm):00012         SOFT_SWI     = $000A    ; SWI / SYS Software Interrupt Vector
     000C             (   memory_map.asm):00013         SOFT_NMI     = $000C    ; NMI Software Interrupt Vector
     000E             (   memory_map.asm):00014         SOFT_RESET   = $000E    ; RESET Software Interrupt Vector
                      (   memory_map.asm):00015                 
     0010             (   memory_map.asm):00016         ZERO_PAGE    = $0010  
     0100             (   memory_map.asm):00017         SYSTEM_STACK = $0100  
     0300             (   memory_map.asm):00018         SSTACK_TOP   = $0300    ; Top of the system stack space
     0300             (   memory_map.asm):00019         USER_STACK   = $0300  
     0400             (   memory_map.asm):00020         USTACK_TOP   = $0400    ; Top of the user stack space
                      (   memory_map.asm):00021                 
                      (   memory_map.asm):00022                   ; Display Buffer (6K bytes)
     0400             (   memory_map.asm):00023         SCREEN_BUFFER = $0400  
                      (   memory_map.asm):00024                 
                      (   memory_map.asm):00025                   ; Device Registers:
     1C00             (   memory_map.asm):00026         HDW_REGS     = $1C00    ; Begin Device Hardware Registers
                      (   memory_map.asm):00027                 
     1C00             (   memory_map.asm):00028         DSP_GRES     = $1C00    ;  (Byte) Screen Resolution Register
                      (   memory_map.asm):00029                   ; DSP_GRES: BBRR.HHVV
                      (   memory_map.asm):00030                   ;     BB:00 = Standard Graphics 1-bpp (2-color mode)
                      (   memory_map.asm):00031                   ;     BB:01 = Standard Graphics 2-bpp (4-color mode)
                      (   memory_map.asm):00032                   ;     BB:10 = Standard Graphics 4-bpp (16-color mode)
                      (   memory_map.asm):00033                   ;     BB:11 = Standard Graphics 8-bpp (256-color mode)
                      (   memory_map.asm):00034                   ;     RR:00 = 16:9  aspect (1.777778)
                      (   memory_map.asm):00035                   ;     RR:01 = 16:10 aspect (1.600000)
                      (   memory_map.asm):00036                   ;     RR:10 = 16:11 aspect (1.454545)
                      (   memory_map.asm):00037                   ;     RR:11 = 16:12 aspect (1.333333)
                      (   memory_map.asm):00038                   ;     HH:00 = 4x Horizontal Overscan Multiplier
                      (   memory_map.asm):00039                   ;     HH:01 = 3x Horizontal Overscan Multiplier
                      (   memory_map.asm):00040                   ;     HH:10 = 2x Horizontal Overscan Multiplier
                      (   memory_map.asm):00041                   ;     HH:11 = 1x Horizontal Overscan Multiplier
                      (   memory_map.asm):00042                   ;     VV:00 = 4x Vertical Overscan Multiplier
                      (   memory_map.asm):00043                   ;     VV:01 = 3x Vertical Overscan Multiplier
                      (   memory_map.asm):00044                   ;     VV:10 = 2x Vertical Overscan Multiplier
                      (   memory_map.asm):00045                   ;     VV:11 = 1x Vertical Overscan Multiplier
                      (   memory_map.asm):00046                 
     1C01             (   memory_map.asm):00047         DSP_EXT      = $1C01    ;  (Byte) Extended Graphics Register
                      (   memory_map.asm):00048                   ; DSP_EXT: ABCD.EFGG
                      (   memory_map.asm):00049                   ;      AA:00 = Extended Graphics 1bpp (2-color mode) 
                      (   memory_map.asm):00050                   ;      AA:01 = Extended Graphics 2bpp (4-color mode) 
                      (   memory_map.asm):00051                   ;      AA:10 = Extended Graphics 4bpp (16-color mode) 
                      (   memory_map.asm):00052                   ;      AA:11 = Extended Graphics 4bpp (16-color mode) 
                      (   memory_map.asm):00053                   ;      B:0   = Extended Graphics: DISABLED 
                      (   memory_map.asm):00054                   ;      B:1   = Extended Graphics: ENABLED 
                      (   memory_map.asm):00055                   ;      C:0   = Extended Extended Mode: BITMAP 
                      (   memory_map.asm):00056                   ;      C:1   = Extended Extended Mode: TILES 
                      (   memory_map.asm):00057                   ;      D:0   = Standard Graphics: DISABLED 
                      (   memory_map.asm):00058                   ;      D:1   = Standard Graphics: ENABLED 
                      (   memory_map.asm):00059                   ;      E:0   = Standard Display Mode: TEXT 
                      (   memory_map.asm):00060                   ;      E:1   = Standard Display Mode: BITMAP 
                      (   memory_map.asm):00061                   ;      F:0   = VSYNC OFF 
                      (   memory_map.asm):00062                   ;      F:1   = VSYNC ON 
                      (   memory_map.asm):00063                   ;      B:0   = Fullscreen Enabled( emulator only ) 
                      (   memory_map.asm):00064                   ;      B:1   = Windowed Enabled ( emulator only ) 
                      (   memory_map.asm):00065                 
     1C02             (   memory_map.asm):00066         STD_VID_MAX  = $1C02    ;  (Word) Standard Video Buffer Max
                      (   memory_map.asm):00067                 
     1C04             (   memory_map.asm):00068         DSP_ERR      = $1C04    ;  (Byte) Display Sub-System Error Code Register
                      (   memory_map.asm):00069                   ; DSP_ERR: ABCD.EFGH
                      (   memory_map.asm):00070                   ;      A:0   = Standard Buffer Overflow 
                      (   memory_map.asm):00071                   ;      B:0   = Extended Buffer Overflow 
                      (   memory_map.asm):00072                   ;      C:0   = Reserved 
                      (   memory_map.asm):00073                   ;      D:0   = Reserved 
                      (   memory_map.asm):00074                   ;      E:0   = Reserved 
                      (   memory_map.asm):00075                   ;      F:0   = Reserved 
                      (   memory_map.asm):00076                   ;      G:0   = Reserved 
                      (   memory_map.asm):00077                   ;      H:0   = Reserved 
                      (   memory_map.asm):00078                 
                      (   memory_map.asm):00079             ; 5115 ($13FB) bytes remaining for additional registers.
     1C05             (   memory_map.asm):00080         RESERVED     = $1C05  
                      (   memory_map.asm):00081                 
                      (   memory_map.asm):00082                   ; User RAM (32K)
     3000             (   memory_map.asm):00083         USER_RAM     = $3000  
                      (   memory_map.asm):00084                 
                      (   memory_map.asm):00085                   ; Paged RAM (8K)
     B000             (   memory_map.asm):00086         PAGED_RAM    = $B000  
                      (   memory_map.asm):00087                 
                      (   memory_map.asm):00088                   ; PAGED ROM (8K bytes)
     D000             (   memory_map.asm):00089         PAGED_ROM    = $D000  
                      (   memory_map.asm):00090                 
                      (   memory_map.asm):00091                   ; KERNEL ROM (4K bytes)
     F000             (   memory_map.asm):00092         KERNEL_ROM   = $F000  
                      (   memory_map.asm):00093                 
                      (   memory_map.asm):00094                   ; Hardware Interrupt Vectors:
     FFF0             (   memory_map.asm):00095         HARD_RSRVD   = $FFF0    ; Motorola RESERVED Hardware Interrupt Vector
     FFF2             (   memory_map.asm):00096         HARD_SWI3    = $FFF2    ; SWI3 Hardware Interrupt Vector
     FFF4             (   memory_map.asm):00097         HARD_SWI2    = $FFF4    ; SWI2 Hardware Interrupt Vector
     FFF6             (   memory_map.asm):00098         HARD_FIRQ    = $FFF6    ; FIRQ Hardware Interrupt Vector
     FFF8             (   memory_map.asm):00099         HARD_IRQ     = $FFF8    ; IRQ Hardware Interrupt Vector
     FFFA             (   memory_map.asm):00100         HARD_SWI     = $FFFA    ; SWI / SYS Hardware Interrupt Vector
     FFFC             (   memory_map.asm):00101         HARD_NMI     = $FFFC    ; NMI Hardware Interrupt Vector
     FFFE             (   memory_map.asm):00102         HARD_RESET   = $FFFE    ; RESET Hardware Interrupt Vector
                      (   memory_map.asm):00103         ; END of definitions
                      (asm/kernel_f000.a):00002         
                      (asm/kernel_f000.a):00003                 org     $f000   
                      (asm/kernel_f000.a):00004         
                      (asm/kernel_f000.a):00005         ; fill the screen
F000                  (asm/kernel_f000.a):00006         start   
F000 8600             (asm/kernel_f000.a):00007                 lda     #$00
F002 8E0400           (asm/kernel_f000.a):00008                 ldx     #SCREEN_BUFFER
F005                  (asm/kernel_f000.a):00009         lp1     
F005 4C               (asm/kernel_f000.a):00010                 inca
F006 A780             (asm/kernel_f000.a):00011                 sta     ,x+
F008 BC1C02           (asm/kernel_f000.a):00012                 cmpx    STD_VID_MAX
F00B 2FF8             (asm/kernel_f000.a):00013                 ble     lp1
                      (asm/kernel_f000.a):00014         ; increment the screen
F00D                  (asm/kernel_f000.a):00015         inc_screen
F00D 8E0400           (asm/kernel_f000.a):00016                 ldx     #SCREEN_BUFFER
F010                  (asm/kernel_f000.a):00017         lp2
F010 6C80             (asm/kernel_f000.a):00018                 inc     ,x+
F012 BC1C02           (asm/kernel_f000.a):00019                 cmpx    STD_VID_MAX
F015 2FF9             (asm/kernel_f000.a):00020                 ble     lp2
                      (asm/kernel_f000.a):00021         
F017 20F4             (asm/kernel_f000.a):00022                 bra     inc_screen
                      (asm/kernel_f000.a):00023         
                      (asm/kernel_f000.a):00024         
                      (asm/kernel_f000.a):00025         
                      (asm/kernel_f000.a):00026         
                      (asm/kernel_f000.a):00027                 org     $fffe
FFFE F000             (asm/kernel_f000.a):00028                 fdb     $F000   ; HARD_RESET
