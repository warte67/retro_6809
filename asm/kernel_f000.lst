F2C5  2726                            beq     str1_cmp_term   ; is a null-terminator? verify other string
F2C7  8120                            cmpa    #' '            ; is it a space character?
F2C9  2722                            beq     str1_cmp_term   ; branch to verify other strings termination
F2CB  8122                            cmpa    #'"'            ; is it a double quote?
