F3A0  2D0A                            blt     0f
F3A2  BDF41A                          jsr     cls
F3A5  3556                            puls    d,x,u
F3A7  3550                            puls    x,u
F3A9  7EF079                          jmp     main_user_input_loop
F3AC                  0       ; continue normally
F3AC  FE0016                          ldu     EDLIN_ANCH      ; point to the edline start of line anchor
F3AF  B61C07                          lda     SYS_TIMER+1     ; load the LSB of the system timer
F3B2  8407                            anda    #$07            ; only concerned with these bits
F3B4  2616                            bne     1f              ; if non-zero, skip color change
F3B6  B60010                          lda     CSR_ATTR        ; load the next cursor color
F3B9  4C                              inca                    ; increment it
F3BA  840F                            anda    #$0f            ; mask off the foreground color
                                      ;ora    #$f0            ; foreground 15 = opaque black
F3BC  B70010                          sta     CSR_ATTR        ; store the new attribute
F3BF  F61C3A                          ldb     EDT_BFR_CSR     ; load the cursor position
F3C2  58                              lslb                    ; skip the attribue
F3C3  5C                              incb                    ; increment the attribute color
F3C4  A7C5                            sta     b, u            ; update the characters color
F3C6  5A                              decb                    ; now index the character
F3C7  33C5                            leau    b,u             ; load that characters address
F3C9  FF0011                          stu     CSR_ADDR        ; store it on the zero-page
F3CC                  1       ; clean up and return   
F3CC  3556                            puls    a,b,x,u         ; pop these off the stack
F3CE  39                              rts                     ; return when done
                      
                      
F3CF                  line_out        ; Display a null terminated string pointed to by X
                                      ; begining at CSR_ROW and CSR_COL.
F3CF  3412                            pshs    a,x             ; store the working registers
F3D1                  1       ; line out main loop
F3D1  A680                            lda     ,x+             ; load the next character to display
F3D3  2707                            beq     2f              ; skip if at null-terminator
F3D5  2B05                            bmi     2f              ; skip if high bit is set
F3D7  BDF3DF                          jsr     char_out        ; output this character
F3DA  20F5                            bra     1b              
F3DC                  2       ; clean up and return
F3DC  3512                            puls    a,x             ; restore the working registers
F3DE  39                              rts                     ; return from subroutine
                      
                      
                      
F3DF                  char_out        ; output a formatted text character based on A
                                      ; jsr   [CHROUT_VECT]
F3DF                  char_out_main   ; the main CHROUT routine
F3DF  3416                            pshs    d,x
                      
F3E1  8120                            cmpa    #$20            ; is a printable character $20 - $ff
F3E3  2C09                            bge     1f              ; yup, go print it
F3E5  810A                            cmpa    #$0a            ; line feed ?
F3E7  2603                            bne     2f              ; no, skip to next
F3E9  BDF437                          jsr     csr_new_line    ; perform a new line
F3EC                  2       ; skip to end
F3EC  2029                            bra     0f              ; just skip everything
F3EE                  1       ; output a printable character $20 - $ff
F3EE  BDF48C                          jsr     cursor_address  ; X = CSR_ADDR          
F3F1  F60015                          ldb     TXT_ATTR        ; fetch the default color attribute
F3F4  ED84                            std     ,x              ; store it on screen
F3F6  7C0013                          inc     CSR_COL         ; increase the cursors column
                                      ; handle line wrap and scrolling
F3F9  B60013                          lda     CSR_COL         ; load cursor column
F3FC  B11C0A                          cmpa    DSP_TXT_COLS    ; compare with max displayed columns
F3FF  2C02                            bge     1f              ; if greater or equal
F401  2014                            bra     0f              ; skip and return
F403                  1       ; if (CSR_COL >= DSP_TXT_COLS)
F403  7F0013                          clr     CSR_COL         ; clear CSR_COL
F406  7C0014                          inc     CSR_ROW         ; increment CSR_ROW
F409  B60014                          lda     CSR_ROW         ; load CSR_ROWS
F40C  B11C0B                          cmpa    DSP_TXT_ROWS    ; if (CSR_ROW < DSP_TXT_ROWS)
F40F  2D06                            blt     0f              ;       clean up and return
F411  BDF456                          jsr     std_text_scroll ; scroll the text screen
F414  7A0014                          dec     CSR_ROW         ; CSR_ROW--
F417                  0       ; clean up and return
F417  3516                            puls    d,x             ; restore the working registers
F419  39                              rts                     ; return
                      
                              
F41A                  cls     ; clear out the text buffer     
F41A  3416                            pshs    d, x            ; store the working registers
F41C  7F0013                          clr     CSR_COL         ; cursor column = 0
F41F  7F0014                          clr     CSR_ROW         ; cursor row = 0
F422  BDF48C                          jsr     cursor_address  ; X = cursor address based on CSR_COL and CSR_ROW
F425  8E0400                          ldx     #SCREEN_BUFFER  ; point to the start of the text buffer
F428  8620                            lda     #$20            ; set next character to space
F42A  F60015                          ldb     TXT_ATTR        ; load the characters color
F42D                  1       ; cls main loop 
F42D  ED81                            std     ,x++            ; store the space with its color attribute
F42F  8C1C00                          cmpx    #STD_VID_MAX    ; are we at the end of the text buffer?
F432  2DF9                            blt     1b              ;       loop if not
F434  3516                            puls    d, x            ; restore the working registers
F436  39                              rts                     ; return
                      
                      
F437                  csr_new_line    ; perform a line-feed and a carriage return with scrolling
F437  3412                            pshs    a, x            ; store the working registers
F439  7F0013                          clr     CSR_COL         ; set cursor column to zero
F43C  7C0014                          inc     CSR_ROW         ; increment the cursor row
F43F  B60014                          lda     CSR_ROW         ; A = cursor row
F442  B11C0B                          cmpa    DSP_TXT_ROWS    ; skip if the current cursor row
F445  2D06                            blt     1f              ;   is less than the max rows
F447  7A0014                          dec     CSR_ROW         ; decrease the cursors row
F44A  BDF456                          jsr     std_text_scroll ; scroll the text up one line
F44D                  1       ; recalculate the cursor address based on CSR_ROW and CSR_COL
F44D  BDF48C                          jsr     cursor_address  ; X = CSR_ADDR based on CSR_ROW and CSR_COL
F450  BF0011                          stx     CSR_ADDR        ; update CSR_ADDR 
F453  3512                            puls    a,x             ; restore the working registers
F455  39                              rts                     ; return from the line editor subroutine
                      
                      
                      
F456                  std_text_scroll ; scroll the standard text screen up one line
F456  3436                            pshs    d, x, y         ; store the working registers
F458  108E0400                        ldy     #SCREEN_BUFFER  ; Y = start of the standard video buffer
F45C  F61C0A                          ldb     DSP_TXT_COLS    ; B = number of displayed text columns
                                      ;lslb                   ; B = B * 2 -- account for the attribute byte
F45F  8E0400                          ldx     #SCREEN_BUFFER  ; X = start of the standard video buffer
                                      ; B can become negative in the 4x horizontal overscan modes
                                      ;       instead of shifting B left and using it to index once
                                      ;       simply load effective address twice
F462  3085                            leax    b,x             ; X = one line down
F464  3085                            leax    b,x             ; X = one line down
F466                  1       ; scroll up one line
F466  EC81                            ldd     ,x++            ; load character at X 
F468  EDA1                            std     ,y++            ; store it at Y
F46A  BC1C00                          cmpx    STD_VID_MAX     ; at the end of the display?
F46D  2DF7                            blt     1b              ; loop if not
                              ; fill the bottom line with spaces
F46F  8E0400                          ldx     #SCREEN_BUFFER  ; X = start of the standard video buffer
F472  F61C0B                          ldb     DSP_TXT_ROWS    ; B = number of displayed rows
F475  5A                              decb                    ; B = B - 1  last line
F476  58                              lslb                    ; B = B * 1 -- account for the attribute byte
F477  B61C0A                          lda     DSP_TXT_COLS    ; A = number of displayed text columns
F47A  3D                              mul                     ; D = A * B
F47B  308B                            leax    d,x             ; X = the start of the bottom row
F47D  8620                            lda     #$20            ; load up default space character
F47F  F60015                          ldb     TXT_ATTR        ; and the default color
F482                  2       ; store the character with its color attribute
F482  ED81                            std     ,x++            ; store the space at X
F484  BC1C00                          cmpx    STD_VID_MAX     ; at the end of the text buffer
F487  2DF9                            blt     2b              ; loop if not
                              ; return
F489  3536                            puls    d,x,y           ; restore the working registers
F48B  39                              rts
                      
                      
F48C                  cursor_address  ; Update CSR_ADDR and return the cursor address in X 
                                      ; based on CSR_COL and CSR_ROW.
F48C  3406                            pshs    d               ; store used registers
F48E  8E0400                          ldx     #SCREEN_BUFFER  ; start of the standard video buffer
F491  B60014                          lda     CSR_ROW         ; A = current cursor row
F494  F61C0A                          ldb     DSP_TXT_COLS    ; B = number of columns displayed
F497  58                              lslb                    ; B = B * 2 -- account for the attribute byte
F498  3D                              mul                     ; D = A * B
F499  308B                            leax    d,x             ; X = D + X             
F49B  F60013                          ldb     CSR_COL         ; B = current cursor column
F49E  58                              lslb                    ; B = B * 2 -- account for the attribute byte
F49F  3085                            leax    b,x             ; X = B + X
F4A1  BF0011                          stx     CSR_ADDR        ; store the cursor address
F4A4  3506                            puls    d               ; restore used registers
F4A6  39                              rts                     ; return
                      
                      
                      
                      
                      
