F39D  ED81                            std     ,x++            ; store the space with its color attribute
F39F  8C1C00                          cmpx    #STD_VID_MAX    ; are we at the end of the text buffer?
F3A2  2DF9                            blt     1b              ;       loop if not
F3A4  3516                            puls    d, x            ; restore the working registers
F3A6  39                              rts                     ; return
                      
                      
F3A7                  csr_new_line    ; perform a line-feed and a carriage return with scrolling
F3A7  3412                            pshs    a, x            ; store the working registers
F3A9  7F0013                          clr     CSR_COL         ; set cursor column to zero
F3AC  7C0014                          inc     CSR_ROW         ; increment the cursor row
F3AF  B60014                          lda     CSR_ROW         ; A = cursor row
F3B2  B11C0B                          cmpa    DSP_TXT_ROWS    ; skip if the current cursor row
F3B5  2D06                            blt     1f              ;   is less than the max rows
F3B7  7A0014                          dec     CSR_ROW         ; decrease the cursors row
F3BA  BDF3C6                          jsr     std_text_scroll ; scroll the text up one line
F3BD                  1       ; recalculate the cursor address based on CSR_ROW and CSR_COL
F3BD  BDF3FB                          jsr     cursor_address  ; X = CSR_ADDR based on CSR_ROW and CSR_COL
F3C0  BF0011                          stx     CSR_ADDR        ; update CSR_ADDR 
F3C3  3512                            puls    a,x             ; restore the working registers
F3C5  39                              rts                     ; return from the line editor subroutine
                      
                      
                      
F3C6                  std_text_scroll ; scroll the standard text screen up one line
F3C6  3436                            pshs    d, x, y         ; store the working registers
F3C8  108E0400                        ldy     #SCREEN_BUFFER  ; Y = start of the standard video buffer
F3CC  F61C0A                          ldb     DSP_TXT_COLS    ; B = number of displayed text columns
F3CF  58                              lslb                    ; B = B * 2 -- account for the attribute byte
F3D0  8E0400                          ldx     #SCREEN_BUFFER  ; X = start of the standard video buffer
F3D3  3085                            leax    b,x             ; X = one line down
F3D5                  1       ; scroll up one line
F3D5  EC81                            ldd     ,x++            ; load character at X 
F3D7  EDA1                            std     ,y++            ; store it at Y
F3D9  BC1C00                          cmpx    STD_VID_MAX     ; at the end of the display?
F3DC  2DF7                            blt     1b              ; loop if not
                              ; fill the bottom line with spaces
F3DE  8E0400                          ldx     #SCREEN_BUFFER  ; X = start of the standard video buffer
F3E1  F61C0B                          ldb     DSP_TXT_ROWS    ; B = number of displayed rows
F3E4  5A                              decb                    ; B = B - 1  last line
F3E5  58                              lslb                    ; B = B * 1 -- account for the attribute byte
F3E6  B61C0A                          lda     DSP_TXT_COLS    ; A = number of displayed text columns
F3E9  3D                              mul                     ; D = A * B
F3EA  308B                            leax    d,x             ; X = the start of the bottom row
F3EC  8620                            lda     #$20            ; load up default space character
F3EE  F60015                          ldb     TXT_ATTR        ; and the default color
F3F1                  2       ; store the character with its color attribute
F3F1  ED81                            std     ,x++            ; store the space at X
F3F3  BC1C00                          cmpx    STD_VID_MAX     ; at the end of the text buffer
F3F6  2DF9                            blt     2b              ; loop if not
                              ; return
F3F8  3536                            puls    d,x,y           ; restore the working registers
F3FA  39                              rts
                      
                      
F3FB                  cursor_address  ; Update CSR_ADDR and return the cursor address in X 
                                      ; based on CSR_COL and CSR_ROW.
F3FB  3406                            pshs    d               ; store used registers
F3FD  8E0400                          ldx     #SCREEN_BUFFER  ; start of the standard video buffer
F400  B60014                          lda     CSR_ROW         ; A = current cursor row
F403  F61C0A                          ldb     DSP_TXT_COLS    ; B = number of columns displayed
F406  58                              lslb                    ; B = B * 2 -- account for the attribute byte
F407  3D                              mul                     ; D = A * B
F408  308B                            leax    d,x             ; X = D + X             
F40A  F60013                          ldb     CSR_COL         ; B = current cursor column
F40D  58                              lslb                    ; B = B * 2 -- account for the attribute byte
F40E  3085                            leax    b,x             ; X = B + X
F410  BF0011                          stx     CSR_ADDR        ; store the cursor address
F413  3506                            puls    d               ; restore used registers
F415  39                              rts                     ; return
                      
                      
                      
                      
                      
FE00                                  org     $fe00
FE00  526574726F20363830392076302E310A00 prompt0         fcn     "Retro 6809 v0.1\n"
FE11  436F70797269676874202843292032303233204279204A6179204661726965730A0A00 prompt1         fcn     "Copyright (C) 2023 By Jay Faries\n\n"
FE34  52656164790A00  ready_prompt    fcn     "Ready\n"
                      
                      
                      
                      
                      ; ROM Based Hardware Vectors
FFF0                                  org     $FFF0
FFF0  F000                            fdb     KRNL_EXEC       ; HARD_RSRVD       EXEC Interrupt Vector
FFF2  F004                            fdb     KRNL_SWI3       ; HARD_SWI3        SWI3 Hardware Interrupt Vector
FFF4  F008                            fdb     KRNL_SWI2       ; HARD_SWI2        SWI2 Hardware Interrupt Vector
FFF6  F00C                            fdb     KRNL_FIRQ       ; HARD_FIRQ        FIRQ Hardware Interrupt Vector
FFF8  F010                            fdb     KRNL_IRQ        ; HARD_IRQ         IRQ Hardware Interrupt Vector
FFFA  F014                            fdb     KRNL_SWI        ; HARD_SWI         SWI / SYS Hardware Interrupt Vector
FFFC  F018                            fdb     KRNL_NMI        ; HARD_NMI         NMI Hardware Interrupt Vector
FFFE  F01C                            fdb     KRNL_RESET      ; HARD_RESET       RESET Hardware Interrupt Vector
                      
                      
                      ; *****************************************************************
                      ;
                      ;   Text Mode Control Characters ($00 - $1f):
                      ; $00  00000000  Null character
                      ; $01  00000001  Set Default Character #                
                      ; $02  00000010  Set Attribute #                        
                      ; $03  00000011  Set FG Color #                         
                      ; $04  00000100  Set BG Color #                         
                      ; $05  00000101  Position Cursor To Column #            
                      ; $06  00000110  Position Cursor To Row #               
                      ; $07  00000111  Bell, Alert
                      ; $08  00001000  Backspace
                      ; $09  00001001  Horizontal Tab; $0A  00001010  [No Operation]                          
                      ; $0B  00001011                                         
                      ; $0C  00001100  Clear Screen To Default Character      
                      ; $0D  00001101  Carriage Return (ENTER); $0E  00001110                                         
                      ; $0F  00001111                                         
                      ; $10  00010000  Scroll Up                              
                      ; $11  00010001  Scroll Down                            
                      ; $12  00010010  Scroll Left                            
                      ; $13  00010011  Scroll Right                           
                      ; $14  00010100  Cursor Up                              
                      ; $15  00010101  Cursor Down                            
                      ; $16  00010110  Cursor Left                            
                      ; $17  00010111  Cursor Right                           
                      ; $18  00011000  Home Cursor                            
                      ; $19  00011001  Hide Cursor                            
                      ; $1A  00011010  Show Cursor                            
                      ; $1B  00011011  [Escape]; $1C  00011100                                        
                      ; $1D  00011101                                         
                      ; $1E  00011110                                         
                      ; $1F  00011111  Uncontrolled Character ($00-1f)        
                      ;
                      ; *****************************************************************
