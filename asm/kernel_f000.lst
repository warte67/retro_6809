F283                  arg1_8bit_attrib
                              ; returns in A the 2-digit hexidecimal value
                              ;       Z flag set if valid
                              ;       Z flag clear if invalid
                                      ; Decode Argument ONE (color attribute in hex $FB)
F283  3414                            pshs    B,X                     ; store the working registers
F285  BDF2F0                          jsr     decode_command_to_first_argument        ; position X at the start of ARG1
                                      ; default CMD with no argument
F288  A680                            lda     ,x+                     ; laod the first character of the arg1
F28A  272A                            beq     1f                      ; if its a NULL, just do the CLS and return
F28C  8124                            cmpa    #'$'                    ; if its a $
F28E  2704                            beq     2f                      ; check for a valid 8-bit hex value
F290                  3       ; syntax error  (This could become its own standalone subroutine)
F290  1CFB                            andcc   #$FB                    ; clear the Z bit
F292  2024                            bra     0f                      ; clean up and return
F294                  2       ; CMD $## = CMD with 8-bit hexidecimal argument
F294  E602                            ldb     2,x                     ; load two bytes in from the start of arg1
F296  27F8                            beq     3b                      ;       single digit hex is a syntax error
F298  C120                            cmpb    #' '                    ; check fo a space
F29A  26F4                            bne     3b                      ;       single digit hex is a syntax error
F29C                  4       ; X now points to space terminated ARG 1
F29C  4F                              clra                            ; clear the local variable 
F29D  3402                            pshs    A                       ; local in 0,S          
F29F  A680                            lda     ,x+                     ; fetch the next character
F2A1  8DBE                            bsr     decode_16bit_hex_digit  ; convert hex nibble to values 0-15
F2A3  48                              lsla                            ; shift left one bit
F2A4  48                              lsla                            ; shift left one bit
F2A5  48                              lsla                            ; shift left one bit
F2A6  48                              lsla                            ; should now be most significant nibble
F2A7  A7E4                            sta     0,S                     ; update the local
F2A9  A680                            lda     ,x+                     ; load the next character
F2AB  8DB4                            bsr     decode_16bit_hex_digit  ; convert the hex nibble to value 0-15
F2AD  AAE4                            ora     0,S                     ; or it with the local
F2AF  A7E4                            sta     0,S                     ; and update the lcoal
F2B1  3502                            puls    A                       ; A = the local variable
F2B3  B70015                          sta     TXT_ATTR                ; store the new value in the TXT_ATTR
F2B6                  1       ; CMD and return        
F2B6  1A04                            orcc    #$04                    ; set the Z bit
F2B8                  0       ; clean up and return           
F2B8  3514                            puls    B,X                     ; restore the working registers
F2BA  39                              rts                             ; return from subroutine
                      
F2BB                  decode_command_token
                              ; Return:
                              ;       A = Token ID
                              ;       A = $FF command not found
                              ;       X = start of first argument
F2BB  3434                            pshs    B,X,Y
                              ; initial initialization
F2BD  4F                              clra                    ; clear the token ID
F2BE  3402                            pshs    A               ;       store it locally @ 0,S 
F2C0  108EF08B                        ldy     #command_table  ; load the start of the command table
F2C4                  dct_0   ; main loop
F2C4  8E1C3C                          ldx     #EDT_BUFFER     ; load the start of the edit buffer
F2C7  BDF306                          jsr     str_cmp_nmz     ; tokenize the command
F2CA  271A                            beq     dct_cmd_found   ; command was found
                              ; not found at this entry in the table  
F2CC  8E1C3C                          ldx     #EDT_BUFFER     ; reset X to the start of the edit buffer
F2CF                  dct_1   ; progress Y to the next entry
F2CF  A6A0                            lda     ,y+             ; load character in the list entry
F2D1  81FF                            cmpa    #$ff            ; end of list?
F2D3  2604                            bne     dct_2           ;       no, continue
F2D5  A7E4                            sta     0,S             ; store the end-of-list as token ID
F2D7  2008                            bra     dct_cmd_not_found       ; cleanup and restore
F2D9                  dct_2   ; loop conditions
F2D9  8100                            cmpa    #$00            ; is it a null-terminator?
F2DB  26F2                            bne     dct_1           ; nope not yet, loop
F2DD  6CE4                            inc     0,S             ; increment the token ID
F2DF  20E3                            bra     dct_0           ; loop to start checking the next entry
F2E1                  dct_cmd_not_found
