F3B6  270F                            beq     3f              ; if theres no character, display the cursor
F3B8                  2       ; display up to the cursor position
F3B8  A6A0                            lda     ,y+             ; fetch a character from the edit buffer
F3BA  270B                            beq     3f              ; null character (end of line)
F3BC  F60015                          ldb     TXT_ATTR        ; color attribute
F3BF  ED81                            std     ,x++            ; display the character with its color  
F3C1  6AE4                            dec     0,s             ; decrease the local cursor position
F3C3  270C                            beq     4f              ; brach if the cursor is over a character
F3C5  20F1                            bra     2b              ; continue displaying characters
F3C7                  3       ; cursor at end of the line
F3C7  3502                            puls    a               ; repair the stack
F3C9  8620                            lda     #$20            ; load a space
F3CB  A781                            sta     ,x++            ; display the space
F3CD  8D15                            bsr     flash_the_cursor        
F3CF  20A2                            bra     6b              ; loop and display changes in the edit buffer
F3D1                  4       ; cursor over a character
F3D1  3502                            puls    a               ; clean up the stack
F3D3  A6A0                            lda     ,y+             ; load the next character from the buffer
F3D5  A781                            sta     ,x++            ; ignore the attribute
                              ; flash the cursor
F3D7  8D0B                            bsr     flash_the_cursor
F3D9                  5       ; finish the line
F3D9  A6A0                            lda     ,y+             ; load the next character from the buffer
F3DB  2796                            beq     6b              ; loop back to the top if done
F3DD  F60015                          ldb     TXT_ATTR        ; load the basic screen attribute
F3E0  ED81                            std     ,x++            ; display the next character with its color
F3E2  20F5                            bra     5b              ; continue until the line is finished
                      
F3E4                  flash_the_cursor
F3E4  3456                            pshs    a,b,x,u         ; save these on the stack
                              ; check to see if the cursor is below the visible screen
                              ; this can happen if the overscan registers have changed
                              ; when it does happen, simply clean up the stack
                              ; and jmp to the main input loop
F3E6  FE0011                          ldu     CSR_ADDR
F3E9  11B31C00                        cmpu    STD_VID_MAX
F3ED  2D0A                            blt     0f
F3EF  BDF467                          jsr     cls
F3F2  3556                            puls    d,x,u
F3F4  3550                            puls    x,u
F3F6  7EF079                          jmp     main_user_input_loop
F3F9                  0       ; continue normally
F3F9  FE0016                          ldu     EDLIN_ANCH      ; point to the edline start of line anchor
F3FC  B61C07                          lda     SYS_TIMER+1     ; load the LSB of the system timer
F3FF  8407                            anda    #$07            ; only concerned with these bits
F401  2616                            bne     1f              ; if non-zero, skip color change
F403  B60010                          lda     CSR_ATTR        ; load the next cursor color
F406  4C                              inca                    ; increment it
F407  840F                            anda    #$0f            ; mask off the foreground color
                                      ;ora    #$f0            ; foreground 15 = opaque black
F409  B70010                          sta     CSR_ATTR        ; store the new attribute
F40C  F61C3A                          ldb     EDT_BFR_CSR     ; load the cursor position
F40F  58                              lslb                    ; skip the attribue
F410  5C                              incb                    ; increment the attribute color
F411  A7C5                            sta     b, u            ; update the characters color
F413  5A                              decb                    ; now index the character
F414  33C5                            leau    b,u             ; load that characters address
F416  FF0011                          stu     CSR_ADDR        ; store it on the zero-page
F419                  1       ; clean up and return   
F419  3556                            puls    a,b,x,u         ; pop these off the stack
F41B  39                              rts                     ; return when done
                      
                      
F41C                  line_out        ; Display a null terminated string pointed to by X
                                      ; begining at CSR_ROW and CSR_COL.
F41C  3412                            pshs    a,x             ; store the working registers
F41E                  1       ; line out main loop
F41E  A680                            lda     ,x+             ; load the next character to display
F420  2707                            beq     2f              ; skip if at null-terminator
F422  2B05                            bmi     2f              ; skip if high bit is set
F424  BDF42C                          jsr     char_out        ; output this character
F427  20F5                            bra     1b              
F429                  2       ; clean up and return
F429  3512                            puls    a,x             ; restore the working registers
F42B  39                              rts                     ; return from subroutine
                      
                      
                      
F42C                  char_out        ; output a formatted text character based on A
                                      ; jsr   [CHROUT_VECT]
F42C                  char_out_main   ; the main CHROUT routine
F42C  3416                            pshs    d,x
                      
F42E  8120                            cmpa    #$20            ; is a printable character $20 - $ff
F430  2C09                            bge     1f              ; yup, go print it
F432  810A                            cmpa    #$0a            ; line feed ?
F434  2603                            bne     2f              ; no, skip to next
F436  BDF484                          jsr     csr_new_line    ; perform a new line
F439                  2       ; skip to end
F439  2029                            bra     0f              ; just skip everything
F43B                  1       ; output a printable character $20 - $ff
F43B  BDF4D9                          jsr     cursor_address  ; X = CSR_ADDR          
F43E  F60015                          ldb     TXT_ATTR        ; fetch the default color attribute
F441  ED84                            std     ,x              ; store it on screen
F443  7C0013                          inc     CSR_COL         ; increase the cursors column
                                      ; handle line wrap and scrolling
F446  B60013                          lda     CSR_COL         ; load cursor column
F449  B11C0A                          cmpa    DSP_TXT_COLS    ; compare with max displayed columns
F44C  2C02                            bge     1f              ; if greater or equal
F44E  2014                            bra     0f              ; skip and return
F450                  1       ; if (CSR_COL >= DSP_TXT_COLS)
F450  7F0013                          clr     CSR_COL         ; clear CSR_COL
F453  7C0014                          inc     CSR_ROW         ; increment CSR_ROW
F456  B60014                          lda     CSR_ROW         ; load CSR_ROWS
F459  B11C0B                          cmpa    DSP_TXT_ROWS    ; if (CSR_ROW < DSP_TXT_ROWS)
F45C  2D06                            blt     0f              ;       clean up and return
F45E  BDF4A3                          jsr     std_text_scroll ; scroll the text screen
F461  7A0014                          dec     CSR_ROW         ; CSR_ROW--
F464                  0       ; clean up and return
F464  3516                            puls    d,x             ; restore the working registers
F466  39                              rts                     ; return
                      
                              
F467                  cls     ; clear out the text buffer     
F467  3416                            pshs    d, x            ; store the working registers
F469  7F0013                          clr     CSR_COL         ; cursor column = 0
F46C  7F0014                          clr     CSR_ROW         ; cursor row = 0
F46F  BDF4D9                          jsr     cursor_address  ; X = cursor address based on CSR_COL and CSR_ROW
F472  8E0400                          ldx     #SCREEN_BUFFER  ; point to the start of the text buffer
F475  8620                            lda     #$20            ; set next character to space
F477  F60015                          ldb     TXT_ATTR        ; load the characters color
F47A                  1       ; cls main loop 
F47A  ED81                            std     ,x++            ; store the space with its color attribute
F47C  8C1C00                          cmpx    #STD_VID_MAX    ; are we at the end of the text buffer?
F47F  2DF9                            blt     1b              ;       loop if not
F481  3516                            puls    d, x            ; restore the working registers
F483  39                              rts                     ; return
                      
                      
F484                  csr_new_line    ; perform a line-feed and a carriage return with scrolling
F484  3412                            pshs    a, x            ; store the working registers
F486  7F0013                          clr     CSR_COL         ; set cursor column to zero
F489  7C0014                          inc     CSR_ROW         ; increment the cursor row
F48C  B60014                          lda     CSR_ROW         ; A = cursor row
F48F  B11C0B                          cmpa    DSP_TXT_ROWS    ; skip if the current cursor row
F492  2D06                            blt     1f              ;   is less than the max rows
F494  7A0014                          dec     CSR_ROW         ; decrease the cursors row
F497  BDF4A3                          jsr     std_text_scroll ; scroll the text up one line
F49A                  1       ; recalculate the cursor address based on CSR_ROW and CSR_COL
F49A  BDF4D9                          jsr     cursor_address  ; X = CSR_ADDR based on CSR_ROW and CSR_COL
F49D  BF0011                          stx     CSR_ADDR        ; update CSR_ADDR 
F4A0  3512                            puls    a,x             ; restore the working registers
F4A2  39                              rts                     ; return from the line editor subroutine
                      
                      
                      
F4A3                  std_text_scroll ; scroll the standard text screen up one line
F4A3  3436                            pshs    d, x, y         ; store the working registers
F4A5  108E0400                        ldy     #SCREEN_BUFFER  ; Y = start of the standard video buffer
F4A9  F61C0A                          ldb     DSP_TXT_COLS    ; B = number of displayed text columns
                                      ;lslb                   ; B = B * 2 -- account for the attribute byte
F4AC  8E0400                          ldx     #SCREEN_BUFFER  ; X = start of the standard video buffer
                                      ; B can become negative in the 4x horizontal overscan modes
                                      ;       instead of shifting B left and using it to index once
                                      ;       simply load effective address twice
F4AF  3085                            leax    b,x             ; X = one line down
F4B1  3085                            leax    b,x             ; X = one line down
F4B3                  1       ; scroll up one line
F4B3  EC81                            ldd     ,x++            ; load character at X 
F4B5  EDA1                            std     ,y++            ; store it at Y
F4B7  BC1C00                          cmpx    STD_VID_MAX     ; at the end of the display?
F4BA  2DF7                            blt     1b              ; loop if not
                              ; fill the bottom line with spaces
F4BC  8E0400                          ldx     #SCREEN_BUFFER  ; X = start of the standard video buffer
F4BF  F61C0B                          ldb     DSP_TXT_ROWS    ; B = number of displayed rows
F4C2  5A                              decb                    ; B = B - 1  last line
F4C3  58                              lslb                    ; B = B * 1 -- account for the attribute byte
F4C4  B61C0A                          lda     DSP_TXT_COLS    ; A = number of displayed text columns
F4C7  3D                              mul                     ; D = A * B
F4C8  308B                            leax    d,x             ; X = the start of the bottom row
F4CA  8620                            lda     #$20            ; load up default space character
F4CC  F60015                          ldb     TXT_ATTR        ; and the default color
F4CF                  2       ; store the character with its color attribute
F4CF  ED81                            std     ,x++            ; store the space at X
F4D1  BC1C00                          cmpx    STD_VID_MAX     ; at the end of the text buffer
F4D4  2DF9                            blt     2b              ; loop if not
                              ; return
F4D6  3536                            puls    d,x,y           ; restore the working registers
F4D8  39                              rts
                      
                      
F4D9                  cursor_address  ; Update CSR_ADDR and return the cursor address in X 
                                      ; based on CSR_COL and CSR_ROW.
F4D9  3406                            pshs    d               ; store used registers
F4DB  8E0400                          ldx     #SCREEN_BUFFER  ; start of the standard video buffer
F4DE  B60014                          lda     CSR_ROW         ; A = current cursor row
F4E1  F61C0A                          ldb     DSP_TXT_COLS    ; B = number of columns displayed
F4E4  58                              lslb                    ; B = B * 2 -- account for the attribute byte
F4E5  3D                              mul                     ; D = A * B
F4E6  308B                            leax    d,x             ; X = D + X             
F4E8  F60013                          ldb     CSR_COL         ; B = current cursor column
F4EB  58                              lslb                    ; B = B * 2 -- account for the attribute byte
F4EC  3085                            leax    b,x             ; X = B + X
F4EE  BF0011                          stx     CSR_ADDR        ; store the cursor address
F4F1  3506                            puls    d               ; restore used registers
F4F3  39                              rts                     ; return
                      
                      
                      
                      
                      
