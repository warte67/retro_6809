F26A                  decode_16bit_hex_digit
                              ; decode the LSB of the A accumilator into a value from 0-15
                              ; return B = 0-15   or $ff for invalid
F26A  3404                            pshs    B               ; store the working registers
F26C  1F89                            tfr     A, B            ; transfer input A to working value B
F26E  C030                            subb    #'0'            ; subtract the ascii value of 0
F270  C109                            cmpb    #$09            ; compare it to 9
F272  2E02                            bgt     1f              ; if its greater than 9 it's garbage
F274  2011                            bra     0f              ; otherwise its's valid 
F276                  1       ; check for alpha character
F276  1F89                            tfr     A, B            ; transfer input A to working value B
F278  CA20                            orb     #$20            ; force alpha character to lowercase
F27A  C166                            cmpb    #'f'            ; if the character is greater than F
F27C  2E04                            bgt     2f              ;       it's invalid
F27E  C057                            subb    #'a'-10         ; convert ascii to numeric value
F280  2005                            bra     0f              ; we're done, clean and return
F282                  2       ; invalid character
F282  3504                            puls    B               ; restore the stack
F284  86FF                            lda     #$ff            ; load $ff as an error code
F286  39                              rts                     ; return from subroutine
F287                  0       ; clean up and return
F287  1F98                            tfr     B, A            ; return the result to A
F289  3504                            puls    B               ; restore the stack             
F28B  39                              rts                     ; return from subroutine
                      
                      
                      ; TODO:  This sub needs to be generalized; read arg1 as a raw hex number
                      ;               remove the TXT_ATTRIB stuff
                      ;
F28C                  arg1_8bit_attrib
                              ; returns in A the 2-digit hexidecimal value
                              ;       Z flag set if valid
                              ;       Z flag clear if invalid
                                      ; Decode Argument ONE (color attribute in hex $FB)
F28C  3414                            pshs    B,X                     ; store the working registers
F28E  BDF2F9                          jsr     decode_command_to_first_argument        ; position X at the start of ARG1
                                      ; default CMD with no argument
F291  A680                            lda     ,x+                     ; laod the first character of the arg1
F293  272A                            beq     1f                      ; if its a NULL, just do the CLS and return
F295  8124                            cmpa    #'$'                    ; if its a $
F297  2704                            beq     2f                      ; check for a valid 8-bit hex value
F299                  3       ; syntax error  (This could become its own standalone subroutine)
F299  1CFB                            andcc   #$FB                    ; clear the Z bit
F29B  2024                            bra     0f                      ; clean up and return
F29D                  2       ; CMD $## = CMD with 8-bit hexidecimal argument
F29D  E602                            ldb     2,x                     ; load two bytes in from the start of arg1
F29F  27F8                            beq     3b                      ;       single digit hex is a syntax error
F2A1  C120                            cmpb    #' '                    ; check fo a space
F2A3  26F4                            bne     3b                      ;       single digit hex is a syntax error
F2A5                  4       ; X now points to space terminated ARG 1
F2A5  4F                              clra                            ; clear the local variable 
F2A6  3402                            pshs    A                       ; local in 0,S          
F2A8  A680                            lda     ,x+                     ; fetch the next character
F2AA  8DBE                            bsr     decode_16bit_hex_digit  ; convert hex nibble to values 0-15
F2AC  48                              lsla                            ; shift left one bit
F2AD  48                              lsla                            ; shift left one bit
F2AE  48                              lsla                            ; shift left one bit
F2AF  48                              lsla                            ; should now be most significant nibble
F2B0  A7E4                            sta     0,S                     ; update the local
F2B2  A680                            lda     ,x+                     ; load the next character
F2B4  8DB4                            bsr     decode_16bit_hex_digit  ; convert the hex nibble to value 0-15
F2B6  AAE4                            ora     0,S                     ; or it with the local
F2B8  A7E4                            sta     0,S                     ; and update the lcoal
F2BA  3502                            puls    A                       ; A = the local variable
F2BC  B70015                          sta     TXT_ATTR                ; store the new value in the TXT_ATTR
F2BF                  1       ; CMD and return        
F2BF  1A04                            orcc    #$04                    ; set the Z bit
F2C1                  0       ; clean up and return           
F2C1  3514                            puls    B,X                     ; restore the working registers
F2C3  39                              rts                             ; return from subroutine
                      
F2C4                  decode_command_token
                              ; Return:
                              ;       A = Token ID
                              ;       A = $FF command not found
                              ;       X = start of first argument
F2C4  3434                            pshs    B,X,Y
                              ; initial initialization
F2C6  4F                              clra                    ; clear the token ID
F2C7  3402                            pshs    A               ;       store it locally @ 0,S 
F2C9  108EF08F                        ldy     #command_table  ; load the start of the command table
F2CD                  dct_0   ; main loop
F2CD  8E1C3E                          ldx     #EDT_BUFFER     ; load the start of the edit buffer
F2D0  BDF30F                          jsr     str_cmp_nmz     ; tokenize the command
F2D3  271A                            beq     dct_cmd_found   ; command was found
                              ; not found at this entry in the table  
F2D5  8E1C3E                          ldx     #EDT_BUFFER     ; reset X to the start of the edit buffer
F2D8                  dct_1   ; progress Y to the next entry
F2D8  A6A0                            lda     ,y+             ; load character in the list entry
F2DA  81FF                            cmpa    #$ff            ; end of list?
F2DC  2604                            bne     dct_2           ;       no, continue
F2DE  A7E4                            sta     0,S             ; store the end-of-list as token ID
F2E0  2008                            bra     dct_cmd_not_found       ; cleanup and restore
F2E2                  dct_2   ; loop conditions
F2E2  8100                            cmpa    #$00            ; is it a null-terminator?
F2E4  26F2                            bne     dct_1           ; nope not yet, loop
F2E6  6CE4                            inc     0,S             ; increment the token ID
F2E8  20E3                            bra     dct_0           ; loop to start checking the next entry
F2EA                  dct_cmd_not_found
F2EA  8EF0D4                          ldx     #err_syntax     ; load address of the "ERROR: Syntax" string
F2ED  2002                            bra     dct_output      ; go output the syntax error string
F2EF                  dct_cmd_found   ; command was found in the table
F2EF  2003                            bra     dct_done        ; skip to routine done
F2F1                  dct_output      ; output the status string
F2F1  BDF420                          jsr     line_out        ; output the syntax error
F2F4                  dct_done        ; clean up and return
F2F4  3502                            puls    A               ; clean up the stack, Token ID in A
F2F6  3534                            puls    B,X,Y           ; restore the working registers
F2F8  39                              rts                     ; return from subroutine
                      
F2F9                  decode_command_to_first_argument
                              ; look for the first ' ' or '$' character to start ARG1
                              ; null character is end
F2F9  3402                            pshs    A
F2FB  8E1C3E                          ldx     #EDT_BUFFER     ; point to the start of the edit buffer
F2FE                  1
F2FE  A680                            lda     ,x+             ; fetch next character from the buffer
F300  270A                            beq     dctfa_done      ; branch if null-terminator?
F302  8120                            cmpa    #' '
F304  2706                            beq     dctfa_done
F306  8124                            cmpa    #'$'
F308  2702                            beq     dctfa_done
F30A  20F2                            bra     1b
F30C                  dctfa_done
F30C  3502                            puls    A
F30E  39                              rts
                      
                      
                      
F30F                  str_cmp_nmz     ; compare two null/space/"-terminated strings
                                      ;       on return:
                                      ;       A = tokenized command
                                      ;       X points to argument 1
                                      ;       Y points to argument 2
                                      ;       returns: compare condition in the Z and N condition flags
F30F  3434                            pshs    B,X,Y           ; store the working registers
F311  8600                            lda     #0              ; clear the token flag
F313  3402                            pshs    A               ;       and store it locally @ 0,S
F315                  str_cmp_loop    ; is the string 1 character a terminator?
F315  A684                            lda     ,x              ; fetch a character from the first string
F317  2726                            beq     str1_cmp_term   ; is a null-terminator? verify other string
F319  8120                            cmpa    #' '            ; is it a space character?
F31B  2722                            beq     str1_cmp_term   ; branch to verify other strings termination
F31D  8122                            cmpa    #'"'            ; is it a double quote?
F31F  271E                            beq     str1_cmp_term   ; branch to verify other strings termination
F321  810D                            cmpa    #$0d            ; is it an ENTER character?
F323  271A                            beq     str1_cmp_term   ; branch to verify other strings termination
                                      ; is the string 2 character a terminator?
F325  E6A4                            ldb     ,y              ; fetch a character from the second string
F327  2728                            beq     str2_cmp_term   ; is a null-terminator? verify other string
F329  C120                            cmpb    #' '            ; is it a space character?
F32B  2724                            beq     str2_cmp_term   ; branch to verify other strings termination
F32D  C122                            cmpb    #'"'            ; is it a double-quote character?
F32F  2720                            beq     str2_cmp_term   ; branch to verify other strings termination
F331  C10D                            cmpb    #$0d            ; is it an ENTER character?
F333  271C                            beq     str2_cmp_term   ; branch to verify other strings termination
F335                  str_cmp_equal   ; are characters are same, loop
F335  8A20                            ora     #$20            ; A to lowercase
F337  3001                            leax    1,x             ; increment X
F339  A1A0                            cmpa    ,y+             ; compare characters and increment Y
F33B  27D8                            beq     str_cmp_loop    ; loop if characters are equal
F33D  2024                            bra     str_cmp_differ  ; loop finished, not equal
F33F                  str1_cmp_term   ; string 1 has terminated, check string 2 termination
F33F  E6A4                            ldb     ,y              ; load a character from the second string
F341  2724                            beq     str_cmp_done    ; is it a null-terminator? strings are equal
F343  C120                            cmpb    #' '            ; is it a SPACE terminator?
F345  2720                            beq     str_cmp_done    ;       strings are equal
F347  C122                            cmpb    #'"'            ; is it a double-quote terminator?
F349  271C                            beq     str_cmp_done    ;       strings are equal
F34B  C10D                            cmpb    #$0d            ; is it an ENTER terminator?
F34D  2718                            beq     str_cmp_done    ;       strings are equal
F34F  2012                            bra     str_cmp_differ  ; otherwise, strings are different
F351                  str2_cmp_term   ; string 2 has terminated, check string 1 for termination
F351  A684                            lda     ,x              ; load a character from the first string
F353  2712                            beq     str_cmp_done    ; is it a null-terminator? strings are equal
F355  8120                            cmpa    #' '            ; is it SPACE terminator?
F357  270E                            beq     str_cmp_done    ;       strings are equal
F359  8122                            cmpa    #'"'            ; is it a double-space terminator?
F35B  270A                            beq     str_cmp_done    ;       strings are equal
F35D  810D                            cmpa    #$0d            ; is it an ENTER terminator?
F35F  2706                            beq     str_cmp_done    ;       strings are equal
F361  2000                            bra     str_cmp_differ  ; otherwise, strings are different
                                      ; characters differ, drop out
F363  86FF            str_cmp_differ  lda     #$ff            ; set the token flag
F365  A7E4                            sta     0,S             ;       store it locally @ 0,S
F367                  str_cmp_done    ; done comparing the two strings
                                      ; tst   0,S             ; set the CC appropriate to the local flag (0,S)
F367  3502                            puls    A               ; correct the stack
F369  3534                            puls    B,X,Y           ; restore the working registers
F36B  8100                            cmpa    #$00
F36D  39                              rts                     ; return
                      
                      
                      
                      
                      
                      
                      ; output the line edit buffer
F36E                  line_edit
                      ;       ; clear out the input queue
                      ;               lda     CHAR_Q_LEN
                      ;               beq     8f
                      ;9              lda     CHAR_POP
                      ;               bne     9b
                      ;8
F36E  86FF                            lda     #$ff            ; 'true'
F370  B71C3D                          sta     EDT_ENABLE      ; enable the hardware line editor sub-system
F373  7F1C3E                          clr     EDT_BUFFER      ; null the start of the edit buffer
F376  FC0011                          ldd     CSR_ADDR        ; fetch the current cursor address
F379  FD0016                          std     EDLIN_ANCH      ; store it as the anchor
F37C                  6       ; check for ENTER press
F37C  B61C2B                          lda     CHAR_POP        ; scan for a character waiting in the queue
F37F  810D                            cmpa    #$0d            ; is it the ENTER key?
F381  2627                            bne     0f              ; nope, continue to render the text line editor
                                      ; lda   CHAR_POP        ; pop the ENTER from the queue before returning
F383  8620                            lda     #$20            ; load a space
F385  F60015                          ldb     TXT_ATTR        ; with color
F388  ED9F0011                        std     [CSR_ADDR]      ; overrite the last colored cursor
                                      ; home the cursor
F38C  7F0013                          clr     CSR_COL         ; CSR_COL = 0
F38F  7C0014                          inc     CSR_ROW         ; CSR_ROW = 0
F392  B60014                          lda     CSR_ROW         ; A - CSR_ROW
F395  B11C0B                          cmpa    DSP_TXT_ROWS    ; last line?
F398  2D06                            blt     7f              ; nope, recalc the new cursor address
F39A  7A0014                          dec     CSR_ROW         ; decrement CSR_ROW
F39D  BDF4A7                          jsr     std_text_scroll ; scroll the text buffer
F3A0                  7       ; recalculate the cursor address based on CSR_ROW and CSR_COL
F3A0  BDF4DD                          jsr     cursor_address  ; find CSR_ADDR based on CSR_ROW and CSR_COL
F3A3  BF0011                          stx     CSR_ADDR        ; store the new CSR_ADDR
F3A6  7F1C3D                          clr     EDT_ENABLE      ; disable the hardware line editor sub-system
F3A9  39                              rts                     ; return from the line editor subroutine
F3AA                  0       ; begin the line edit routine
                                      ; ldu   #STD_VID_MIN    ; reserve the start of the display buffer
                                      ; ldu   EDLIN_ANCH      ; reserve the start of the display buffer
F3AA  108E1C3E                        ldy     #EDT_BUFFER     ; start of the character line edit buffer
                                      ; ldx   #STD_VID_MIN    ; point to the start of the display buffer
F3AE  BE0016                          ldx     EDLIN_ANCH      ; point to the start of the display buffer
F3B1  B61C3C                          lda     EDT_BFR_CSR     ; fetch the cursor position
F3B4  3402                            pshs    a               ; save it on the stack as a local variable      
F3B6  2604                            bne     1f              ; cursor position is not zero, begin text
F3B8  A6A4                            lda     ,y              ; load the first character in the buffer
F3BA  261E                            bne     4f              ; if its not zero, display the cursor
F3BC                  1       ; start of the line
F3BC  B61C3C                          lda     EDT_BFR_CSR     ; load the cursor position
F3BF  270F                            beq     3f              ; if theres no character, display the cursor
F3C1                  2       ; display up to the cursor position
F3C1  A6A0                            lda     ,y+             ; fetch a character from the edit buffer
F3C3  270B                            beq     3f              ; null character (end of line)
F3C5  F60015                          ldb     TXT_ATTR        ; color attribute
F3C8  ED81                            std     ,x++            ; display the character with its color  
F3CA  6AE4                            dec     0,s             ; decrease the local cursor position
F3CC  270C                            beq     4f              ; brach if the cursor is over a character
F3CE  20F1                            bra     2b              ; continue displaying characters
F3D0                  3       ; cursor at end of the line
F3D0  3502                            puls    a               ; repair the stack
F3D2  8620                            lda     #$20            ; load a space
F3D4  A781                            sta     ,x++            ; display the space
F3D6  8D15                            bsr     flash_the_cursor        
F3D8  20A2                            bra     6b              ; loop and display changes in the edit buffer
F3DA                  4       ; cursor over a character
F3DA  3502                            puls    a               ; clean up the stack
F3DC  A6A0                            lda     ,y+             ; load the next character from the buffer
F3DE  A781                            sta     ,x++            ; ignore the attribute
                              ; flash the cursor
F3E0  8D0B                            bsr     flash_the_cursor
F3E2                  5       ; finish the line
F3E2  A6A0                            lda     ,y+             ; load the next character from the buffer
F3E4  2796                            beq     6b              ; loop back to the top if done
F3E6  F60015                          ldb     TXT_ATTR        ; load the basic screen attribute
F3E9  ED81                            std     ,x++            ; display the next character with its color
F3EB  20F5                            bra     5b              ; continue until the line is finished
                      
F3ED                  flash_the_cursor
F3ED  3456                            pshs    a,b,x,u         ; save these on the stack
                              ; check to see if the cursor is below the visible screen
                              ; this can happen if the overscan registers have changed
                              ; when it does happen, simply clean up the stack
                              ; and jmp to the main input loop
F3EF  FE0011                          ldu     CSR_ADDR
F3F2  11B31C00                        cmpu    STD_VID_MAX
F3F6  2D0A                            blt     0f
F3F8  BDF46B                          jsr     cls
F3FB  3556                            puls    d,x,u
F3FD  3550                            puls    x,u
F3FF  7EF07D                          jmp     main_user_input_loop
F402                  0       ; continue normally
F402  FE0016                          ldu     EDLIN_ANCH      ; point to the edline start of line anchor
F405  B61C07                          lda     SYS_TIMER+1     ; load the LSB of the system timer
F408  44                              lsra                    ; shift right
F409  44                              lsra                    ; shift right
F40A  44                              lsra                    ; shift right
                      ;               lsra                    ; shift right
F40B  8407                            anda    #$07            ; only concerned with these bits
F40D  B70010                          sta     CSR_ATTR        ; store the new attribute
F410  F61C3C                          ldb     EDT_BFR_CSR     ; load the cursor position
F413  58                              lslb                    ; skip the attribue
