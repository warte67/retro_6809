F261                  decode_16bit_hex_digit
                              ; decode the LSB of the A accumilator into a value from 0-15
                              ; return B = 0-15   or $ff for invalid
F261  3404                            pshs    B               ; store the working registers
F263  1F89                            tfr     A, B            ; transfer input A to working value B
F265  C030                            subb    #'0'            ; subtract the ascii value of 0
F267  C109                            cmpb    #$09            ; compare it to 9
F269  2E02                            bgt     1f              ; if its greater than 9 it's garbage
F26B  2011                            bra     0f              ; otherwise its's valid 
F26D                  1       ; check for alpha character
F26D  1F89                            tfr     A, B            ; transfer input A to working value B
F26F  CA20                            orb     #$20            ; force alpha character to lowercase
F271  C166                            cmpb    #'f'            ; if the character is greater than F
F273  2E04                            bgt     2f              ;       it's invalid
F275  C057                            subb    #'a'-10         ; convert ascii to numeric value
F277  2005                            bra     0f              ; we're done, clean and return
F279                  2       ; invalid character
F279  3504                            puls    B               ; restore the stack
F27B  86FF                            lda     #$ff            ; load $ff as an error code
F27D  39                              rts                     ; return from subroutine
F27E                  0       ; clean up and return
F27E  1F98                            tfr     B, A            ; return the result to A
F280  3504                            puls    B               ; restore the stack             
F282  39                              rts                     ; return from subroutine
                      
                      
